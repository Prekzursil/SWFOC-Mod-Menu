* text=auto eol=lf

# C# / solution files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=crlf
*.props text eol=lf
*.targets text eol=lf

# Scripts
*.ps1 text eol=crlf
*.py text eol=lf
*.sh text eol=lf

# Data/config
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Treat heavy game/media formats as binary
*.meg binary
*.bik binary
*.alo binary
*.ala binary
*.mtd binary
*.tga binary
*.dds binary
*.wav binary
*.png binary
*.jpg binary
*.ico binary

# ── Incorporated third-party tools + RE knowledge base (2026-06-28) ──────────
# Large/binary blobs tracked via Git LFS so they stay out of the normal git
# pack. Text (JSON/Markdown/JSONL) under these trees stays in normal git.
knowledge-base/callgraph_index.sqlite filter=lfs diff=lfs merge=lfs -text
knowledge-base/**/*.sqlite filter=lfs diff=lfs merge=lfs -text
PetroglyphTools/**/*.dat filter=lfs diff=lfs merge=lfs -text
PetroglyphTools/**/*.meg filter=lfs diff=lfs merge=lfs -text
# Keep these vendored/generated trees out of GitHub language statistics and
# collapse them in diffs (third-party tools / machine-generated RE data).
PetroglyphTools/** linguist-vendored
knowledge-base/** linguist-generated
