<UserControl x:Class="SwfocTrainer.App.Tabs.SavegameEditorTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="1120">

    <!-- 2026-05-22 (iter-289c, spec iter-289 savegame editor tab):
         the WPF view over SavegameEditorTabViewModel. A self-contained
         UserControl that binds against its inherited DataContext — the host
         (a MainWindowV2.xaml TabItem) supplies the view-model. The host
         TabItem + the MainViewModelV2 registration are a follow-up
         editor-polish wiring step; this control is complete on its own. -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: status banner -->
        <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Foreground="White" FontWeight="Bold"
                               Text="Savegame Editor (offline — edits .PetroglyphFoC64Save files at rest)"/>
                    <TextBlock Grid.Column="1" Foreground="#FFD27F" FontWeight="Bold" Margin="12,0,0,0"
                               Text="unsaved edits"
                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Column="2" Foreground="#B3D4F8" FontStyle="Italic" Margin="12,0,0,0"
                               Text="working..."
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                </Grid>
                <TextBlock Foreground="#B3D4F8" TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="Load a save, walk its RGMH chunk tree, edit or delete the micro-chunks of a leaf, validate (and re-anchor) the embedded mod hash, then write the result back. Pure local-file work — SWFOC need not be running."/>
                <TextBlock Margin="0,4,0,0" FontStyle="Italic" Foreground="{DynamicResource MutedForeground}">
                    <Run Text="Status: "/>
                    <Run Text="{Binding Status, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Row 1: file paths -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Save file: " VerticalAlignment="Center"
                       Margin="0,0,6,4" Foreground="{DynamicResource MutedForeground}"/>
            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                     Text="{Binding SavePath, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Full path to a .PetroglyphFoC64Save file to Load, Diagnose or Fix."/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Output file: " VerticalAlignment="Center"
                       Margin="0,0,6,4" Foreground="{DynamicResource MutedForeground}"/>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                     Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Where Save writes the edited document. Auto-suggested as name.edited.ext on Load/Fix."/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Mod data: " VerticalAlignment="Center"
                       Margin="0,0,6,0" Foreground="{DynamicResource MutedForeground}"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding ModDataPath, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="A mod ObjectType XML file, or a directory of them, used to validate / re-anchor the embedded mod hash."/>
        </Grid>

        <!-- Row 2: action buttons + summaries -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <WrapPanel>
                <Button Content="Load" Command="{Binding LoadCommand}"
                        Padding="14,5" Margin="0,0,8,0"
                        ToolTip="Read the Save file and build its editable chunk tree."/>
                <Button Content="Diagnose" Command="{Binding DiagnoseCommand}"
                        Padding="14,5" Margin="0,0,8,0"
                        ToolTip="Report the structural health of the Save file without loading it."/>
                <Button Content="Fix" Command="{Binding FixCommand}"
                        Padding="14,5" Margin="0,0,8,0"
                        ToolTip="Recover a corrupt Save file and load the repaired result."/>
                <Button Content="Save" Command="{Binding SaveCommand}"
                        Padding="14,5" Margin="0,0,16,0"
                        Background="#2D5F3E" Foreground="White" FontWeight="Bold"
                        ToolTip="Serialise the loaded document — every edit applied — to the Output file."/>
                <Button Content="Validate Mod Hash" Command="{Binding ValidateModHashCommand}"
                        Padding="14,5" Margin="0,0,8,0"
                        ToolTip="Compare the loaded save's embedded mod hash against the current Mod data."/>
                <Button Content="Re-Anchor Mod Hash" Command="{Binding ReAnchorModHashCommand}"
                        Padding="14,5"
                        Background="#5A3A1F" Foreground="White"
                        ToolTip="Overwrite the save's stale embedded mod hash so it loads under the current mod."/>
            </WrapPanel>
            <Border Background="{DynamicResource ChromeBackground}" BorderBrush="{DynamicResource ChromeBorder}"
                    BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock>
                        <Run Text="Header:  " FontWeight="Bold"/>
                        <Run Text="{Binding HeaderSummary, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0">
                        <Run Text="Diagnose:  " FontWeight="Bold"/>
                        <Run Text="{Binding DiagnosisSummary, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0">
                        <Run Text="Mod hash:  " FontWeight="Bold"/>
                        <Run Text="{Binding ModHashSummary, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Row 3: chunk tree (left) + micro-chunk editor (right) -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- chunk tree -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource ChromeBorder}"
                    BorderThickness="1" CornerRadius="3" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Chunk tree" FontWeight="Bold"
                               Padding="8,4" Background="{DynamicResource ChromeBackground}"/>
                    <ListBox ItemsSource="{Binding Chunks}"
                             SelectedItem="{Binding SelectedChunk, Mode=TwoWay}"
                             FontFamily="Consolas, Cascadia Mono, monospace"
                             FontSize="12" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Summary}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- micro-chunk editor -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="{DynamicResource ChromeBorder}"
                        BorderThickness="1" CornerRadius="3">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Micro-chunks of the selected leaf"
                                   FontWeight="Bold" Padding="8,4"
                                   Background="{DynamicResource ChromeBackground}"/>
                        <DataGrid ItemsSource="{Binding MicroChunks}"
                                  SelectedItem="{Binding SelectedMicroChunk, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  FontFamily="Consolas, Cascadia Mono, monospace" FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding TypeCodeHex}" Width="60"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding TypeName}" Width="100"/>
                                <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="55"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding ValuePreview}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                <Border Grid.Row="1" BorderBrush="{DynamicResource ChromeBorder}"
                        BorderThickness="1" CornerRadius="3" Margin="0,8,0,0" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Edit value: " VerticalAlignment="Center"
                                   Margin="0,0,6,0" Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas, Cascadia Mono, monospace"
                                 ToolTip="An int32 (decimal or 0x-hex) for an int32 micro-chunk; otherwise a hex byte string."/>
                        <Button Grid.Column="2" Content="Apply edit" Command="{Binding ApplyEditCommand}"
                                Padding="12,4" Margin="8,0,8,0"
                                ToolTip="Write Edit value into the selected micro-chunk (in memory; Save to persist)."/>
                        <Button Grid.Column="3" Content="Delete" Command="{Binding DeleteMicroChunkCommand}"
                                Padding="12,4"
                                Background="#7A2A2A" Foreground="White"
                                ToolTip="Remove the selected micro-chunk from its leaf (in memory; Save to persist)."/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
