                                                <TextBlock VerticalAlignment="Center">
                                                    <Run Text="[Index "/>
                                                    <Run Text="{Binding Index, Mode=OneWay}"/>
                                                    <Run Text="] 0x"/>
                                                    <Run Text="{Binding ChildAddr, Mode=OneWay, StringFormat=X16}"/>
                                                    <Run Text=" hp="/>
                                                    <Run Text="{Binding Hp, Mode=OneWay, StringFormat=F3}"/>
