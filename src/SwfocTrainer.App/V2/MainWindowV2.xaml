<Window x:Class="SwfocTrainer.App.V2.MainWindowV2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infra="clr-namespace:SwfocTrainer.App.V2.Infrastructure"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:diag="clr-namespace:SwfocTrainer.Core.Diagnostics;assembly=SwfocTrainer.Core"
        mc:Ignorable="d"
        Title="{Binding WindowTitle, FallbackValue='SWFOC Trainer Editor'}"
        Height="820" Width="1280"
        MinWidth="960" MinHeight="640"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource TextForeground}">
    <Window.Resources>
        <!--
            2026-04-27 (final): All implicit control styles live here in
            Window.Resources because that's the lookup scope WPF actually
            applies to descendant ComboBox/TextBox controls. We tried
            putting them in V2/Themes/Dark.xaml and Light.xaml (so theme
            swaps would re-apply them live), but for ComboBox specifically
            the Application.Resources scope wasn't picking up the implicit
            style — only TextBox worked there. Putting the styles in
            Window.Resources guarantees descendant lookup, and we keep the
            BRUSH values (InputBackground, InputForeground, …) as
            DynamicResource references into the Dark/Light theme dictionaries,
            so theme swap STILL updates colours live without re-applying styles.
        -->
        <!--
            2026-04-27 (iter 51): WPF's built-in BooleanToVisibilityConverter
            for the Diagnostics last-failure callout. Reused for any future
            "show this only when X is true" binding so we don't grow a
            converter-per-feature explosion.
        -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <!--
            2026-04-27 (iter 65): activity-log duration color-coding. Maps
            BridgeActivityEntry.DurationCategory to a theme brush so the
            ms column in the Diagnostics activity DataGrid pops on slow
            calls without operators having to sort by duration.
        -->
        <infra:DurationCategoryToBrushConverter x:Key="DurationCategoryToBrush"/>
        <!--
            2026-04-28 (iter 70): bridge-health dot in the bottom status
            bar. Maps BridgeActivityStats.HealthCategory ("Healthy" /
            "Degraded" / "Failing") to a theme brush so operators see
            recent failure-rate spikes at a glance from any tab.
        -->
        <infra:HealthCategoryToBrushConverter x:Key="HealthCategoryToBrush"/>
        <infra:StringEqualsMultiConverter x:Key="StringEqualsMultiConverter"/>
        <infra:BadgeToIsEnabledConverter x:Key="BadgeToIsEnabled"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputCaretBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ItemSelectedBackground}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource InputForeground}"/>
        </Style>
        <!--
            ComboBoxToggleButtonChrome — used inside the custom ComboBox
            ControlTemplate below as the visual base. This is a private
            style; it should not be used directly anywhere else.
        -->
        <Style x:Key="ComboBoxToggleButtonChrome" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ChromeBorder"
                                Background="{DynamicResource InputBackground}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource ButtonBackground}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1,0,0,0"/>
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{DynamicResource InputForeground}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Full custom ComboBox ControlTemplate. Replaces the default Aero
            template entirely so the field background no longer falls back
            to SystemColors.WindowBrushKey (white). Renders:
              - InputBackground field with InputBorderBrush border
              - Custom dropdown arrow using ButtonBackground
              - High-contrast SelectionBoxItem text (InputForeground)
              - Dark-themed popup that uses ListBackground for items
            Works for both IsEditable=True (with PART_EditableTextBox) and
            IsEditable=False (with ContentPresenter for SelectionBoxItem).
        -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource ComboBoxToggleButtonChrome}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Grid.ColumnSpan="2"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              TextElement.Foreground="{DynamicResource InputForeground}"
                                              TextBlock.Foreground="{DynamicResource InputForeground}"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="{TemplateBinding Padding}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource InputForeground}"
                                     CaretBrush="{DynamicResource InputForeground}"
                                     BorderThickness="0"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Stretch"
                                     Focusable="True"/>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource ListBackground}"
                                        BorderBrush="{DynamicResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer Margin="0">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"
                                                    TextElement.Foreground="{DynamicResource InputForeground}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="40"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DimForeground}"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource ListBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ItemHoverBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ItemHoverForeground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ItemSelectedBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ItemSelectedForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,4"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource HeaderForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ListBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ListForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}"/>
            <Setter Property="FontFamily" Value="Consolas, Lucida Console, monospace"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <!-- 2026-04-27 (iter 11): bottom status bar row. -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource ChromeBackground}" BorderBrush="{DynamicResource BorderBrushStrong}" BorderThickness="1" Padding="10,6" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="SWFOC Trainer Editor" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentForeground}"/>
                    <TextBlock Text="  |  Mode: " Margin="12,0,0,0" Foreground="{DynamicResource MutedForeground}"/>
                    <TextBlock Text="{Binding ModeBadge}" Foreground="{DynamicResource AccentForeground}" FontWeight="Bold"/>
                    <TextBlock Text="  |  Pipe: " Margin="12,0,0,0" Foreground="{DynamicResource MutedForeground}"/>
                    <TextBlock Text="{Binding Diagnostics.PipeName}" Foreground="{DynamicResource AccentForeground}"/>
                </StackPanel>
                <!-- 2026-05-07 (iter 469): Mode switcher. Two segmented buttons; the
                     active mode highlights via DataTrigger. Live mode shows the 25
                     trainer tabs; Savegame mode shows Rescue/Monitor/Auto-Tools. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <Button Content="LIVE TRAINER"
                            Command="{Binding SetLiveModeCommand}"
                            Padding="10,3" MinWidth="120"
                            ToolTip="Show the 25 trainer tabs (requires SwfocExtender.Host attach for LIVE wires).">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLiveMode}" Value="True">
                                        <Setter Property="Background" Value="#2D5F3E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="SAVEGAME EDITOR"
                            Command="{Binding SetSavegameModeCommand}"
                            Padding="10,3" MinWidth="140"
                            ToolTip="Show the offline savegame editor tabs (Rescue / Monitor / Auto-Tools). No SWFOC attach required.">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLiveMode}" Value="False">
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <!--
                    2026-04-27 (iter 12): Help button → opens the live-test
                    smoke checklist in the OS default markdown viewer. Walks
                    the bin directory hierarchy looking for
                    swfoc_memory/knowledge-base/go_live_smoke_checklist_*.md.
                -->
                <Button Grid.Column="2"
                        Content="Help / smoke checklist"
                        Command="{Binding OpenHelpCommand}"
                        Padding="10,3"
                        ToolTip="Open the go-live smoke-test checklist in your default markdown viewer."/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="{DynamicResource TabBackground}" BorderThickness="0">
            <!-- 2026-05-07 (iter 469): Mode switcher. Default TabItem visibility
                 is bound to LiveTabsVisibility (the trainer mode). Savegame tabs
                 override Visibility to SavegameTabsVisibility so they appear only
                 in Savegame Editor mode. The top-bar Mode toggle flips IsLiveMode. -->
            <TabControl.Resources>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Visibility" Value="{Binding LiveTabsVisibility}"/>
                </Style>
            </TabControl.Resources>
            <!-- =================================================== TAB 1: Connection & Diagnostics -->
            <TabItem Header="Connection &amp; Diagnostics">
                <Grid DataContext="{Binding Diagnostics}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/> <!-- iter 74: group-by-command Expander -->
                        <RowDefinition Height="Auto"/> <!-- iter 75: pinned-entries Expander -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="10,6" Margin="0,0,0,8" CornerRadius="3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource DisconnectedBackground}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BridgeReady}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ConnectedBackground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StatusBanner}" FontWeight="Bold" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" MinWidth="100"/>
                        <CheckBox Content="Pipe reachable" IsChecked="{Binding PipeConnected, Mode=OneWay}" IsHitTestVisible="False" Margin="12,0,0,0"/>
                        <!--
                            2026-04-27 (iter 16): continuous bridge monitoring.
                            5s cadence — slow enough to avoid hammering the
                            pipe, fast enough to catch a bridge drop within
                            seconds. Same PeriodicTimer pattern as Inspector
                            + Event Stream auto-refresh.
                        -->
                        <CheckBox Content="Auto-refresh (5s)"
                                  IsChecked="{Binding IsAutoRefreshEnabled}"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  ToolTip="Re-run the diagnostic probes every 5 seconds. Skips silently while a manual Refresh is in flight."/>
                        <!--
                            2026-04-27: aggregate version + build + helpers +
                            self-test + log tail into a single string and
                            put it on the clipboard. Operators raising bug
                            reports get one click instead of four screenshots.
                        -->
                        <Button Content="Copy diagnostics"
                                Command="{Binding CopyDiagnosticsCommand}"
                                Margin="12,0,0,0"
                                ToolTip="Copy version, build info, helpers list, self-test, and log tail to the clipboard for bug reports."/>
                        <!--
                            2026-04-27 (iter 41): one-click open of the
                            auto-generated capability status matrix. The
                            file lives at sibling-checkout swfoc_memory/
                            knowledge-base/capability_status_*.md and is
                            regenerated by the test suite. Status-line
                            message handles the not-found case gracefully.
                        -->
                        <Button Content="Open capability report"
                                Command="{Binding OpenCapabilityReportCommand}"
                                Margin="12,0,0,0"
                                ToolTip="Opens knowledge-base/capability_status_*.md in the OS default markdown viewer. Lists every SWFOC_* helper's live/Phase-2-pending status (auto-generated from CapabilityStatusCatalog)."/>
                        <!-- iter 62: sibling button for the iter-61 surface report
                             which is keyed by tab+button instead of helper name. -->
                        <Button Content="Open surface report"
                                Command="{Binding OpenCapabilitySurfaceReportCommand}"
                                Margin="6,0,0,0"
                                ToolTip="Opens knowledge-base/capability_surface_*.md — every operator-facing button across every editor tab with its catalog badge + note. Sister to the capability report but keyed by tab+button instead of helper name."/>
                        <!-- 2026-05-05 (iter 190): native UX for iter-178 global no-arg
                             getter wires. Operator clicks any of these to read engine
                             state into the diagnostic log below — no input field, just
                             buttons. Continuation of iter-188/189 native-UX surfacing arc.
                             Result lands as `[engine_state] Game mode -> Land` etc. -->
                        <Separator Margin="12,0,12,0" Width="1" Background="{DynamicResource MutedForeground}"/>
                        <Button Content="Game mode" Command="{Binding ReadGameModeCommand}" Margin="0,0,4,0"
                                ToolTip="Calls Get_Game_Mode(). Returns 'Galactic' / 'Land' / 'Space'. Useful for gating tactical-only commands in scripts."/>
                        <Button Content="Local player" Command="{Binding ReadLocalPlayerCommand}" Margin="0,0,4,0"
                                ToolTip="Calls Get_Local_Player(). Returns operator's PlayerWrapper handle. Composes with PlayerGiveMoney for 'give MY player credits' workflows."/>
                        <Button Content="Time scale" Command="{Binding ReadTimeScaleCommand}" Margin="0,0,4,0"
                                ToolTip="Calls Get_Seconds_Per_Game_Minute(). Returns the engine's time-scale float (real-seconds-per-game-minute)."/>
                        <Button Content="Thread stage" Command="{Binding ReadThreadStageCommand}"
                                ToolTip="Calls Thread.Get_Current_Stage(). Returns current cinematic-thread stage int (or 'nil' outside a cinematic). Pair with Game mode for mid-cinematic debugging. Namespace-agnostic — Thread.* dotted name passed transparently to global-no-arg-getter helper."/>
                    </StackPanel>
                    <!--
                        2026-05-05 (iter 207): iter-158 Hide_GUI_Object +
                        iter-166 Show_GUI_Object symmetric pair. Operator
                        workflow: hide an HUD element during cinematic
                        recording, click Show to re-expose afterward. Single
                        shared name field — type once, click either button.
                        Sits below the iter-190/205 read-state row in the
                        Connection panel since it's also "live engine state
                        manipulation" rather than per-feature surface.
                    -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="GUI element:" VerticalAlignment="Center" Margin="0,0,4,0"
                                   ToolTip="Engine GUI element identifier (e.g. Tactical_HUD, Galactic_Top_Bar, Mission_Objectives_Display). Same name fed to both Hide and Show."/>
                        <TextBox Width="180" Text="{Binding GuiObjectElementName, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type the element name once. Hide+Show both consume this field."/>
                        <Button Content="Hide GUI" Command="{Binding HideGuiObjectCommand}" Margin="6,0,4,0"
                                ToolTip="Calls Hide_GUI_Object(name). Useful pre-cinematic to remove HUD clutter from screen recordings."/>
                        <Button Content="Show GUI" Command="{Binding ShowGuiObjectCommand}"
                                ToolTip="Calls Show_GUI_Object(name). Symmetric counterpart to Hide. Restores the element after a cinematic capture."/>
                    </StackPanel>

                    <GroupBox Grid.Row="2" Header="Probes">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!--
                                2026-04-27: tooltips on every probe row.
                                Operators get an inline explanation of what
                                each probe does and what a healthy vs. broken
                                response looks like.
                            -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version: " Margin="0,2,6,2"
                                       ToolTip="SWFOC_GetVersion → bridge build string. Healthy: starts with 'SWFOC Lua Bridge v1.5-dev+a' (or newer). If you see a v1.4 string, the deployed powrprof.dll is older than 2026-04-10."/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VersionText}" Foreground="{DynamicResource AccentForeground}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Build info: " Margin="0,2,6,2"
                                       ToolTip="SWFOC_GetBuildInfo → branch + commit + build date. Helps differentiate freshly-deployed vs. cached DLLs."/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BuildInfoText}" Foreground="{DynamicResource AccentForeground}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Registered helpers: " Margin="0,2,6,2"
                                       ToolTip="SWFOC_DiagListRegisteredFunctions → comma-separated list of every SWFOC_* helper the bridge registered with Lua. Healthy: 60+. Below that = stale DLL."/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding RegisteredHelperCount}" Foreground="{DynamicResource AccentForeground}"/>
                                <TextBlock Text="  (" Foreground="{DynamicResource DimForeground}"/>
                                <TextBlock Text="{Binding RegisteredHelpersText}" Foreground="{DynamicResource MutedForeground}" TextTrimming="CharacterEllipsis" MaxWidth="780"/>
                                <TextBlock Text=")" Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="SelfTest: " Margin="0,2,6,2"
                                       ToolTip="SWFOC_DiagSelfTest → bridge-side smoke test of internal invariants. Healthy: ends with 'failed=0'. Any other 'failed=N' value means N internal checks failed (open the bridge log for detail)."/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelfTestText}" Foreground="{DynamicResource AccentForeground}" TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Log file: " Margin="0,2,6,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LogFilePath}" Foreground="{DynamicResource MutedForeground}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Row="3" Header="Bridge log tail (last 100 lines)">
                        <ListBox ItemsSource="{Binding LogTail}"/>
                    </GroupBox>

                    <!--
                        2026-04-27 (iter 45): operator-visible audit of the
                        last 50 SendRawAsync round-trips. Shows command,
                        outcome, response/error, and duration. Useful for
                        "I clicked X and nothing happened" debugging — the
                        operator can verify whether the call even reached
                        the bridge. RecentBridgeCalls is updated by the
                        Refresh path; auto-refresh keeps it fresh during
                        live monitoring.
                    -->
                    <!--
                        2026-04-27 (iter 51): last-failure callout. Visible
                        only when the activity ring buffer has at least one
                        failed entry. Color-coded amber (matches WarningForeground)
                        so it stands out without being alarming.
                    -->
                    <Border Grid.Row="4"
                            Background="{DynamicResource WarningBackground}"
                            BorderBrush="{DynamicResource WarningBorderBrush}"
                            BorderThickness="1" CornerRadius="2"
                            Padding="8,4" Margin="0,8,0,0"
                            Visibility="{Binding HasRecentFailure, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <!-- iter 79: dismiss button — operator can acknowledge they've seen the
                                 failure. New failures (Timestamp > dismissal) re-surface automatically. -->
                            <Button DockPanel.Dock="Right"
                                    Content="Dismiss"
                                    Command="{Binding DismissLastFailureCommand}"
                                    Padding="6,1" Margin="8,0,0,0" FontSize="10"
                                    ToolTip="Acknowledge this failure and hide the callout. Any newer failure will re-show automatically."/>
                            <TextBlock Text="{Binding LastFailureSummary}"
                                       Foreground="{DynamicResource WarningForeground}"
                                       FontFamily="Consolas, Lucida Console, monospace"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Expander Grid.Row="5" Header="Recent bridge calls (last 50)"
                              IsExpanded="False" Margin="0,8,0,0">
                        <StackPanel>
                            <!--
                                2026-04-27 (iter 46): operator-friendly
                                filter + clipboard export. "Errors only"
                                is the most common bug-chasing workflow;
                                "Copy to clipboard" outputs TSV ready for
                                pasting into a bug report.
                            -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <CheckBox Content="Errors only"
                                          IsChecked="{Binding ActivityLogErrorsOnly}"
                                          VerticalAlignment="Center"
                                          ToolTip="Filter the table to entries where Succeeded=false."/>
                                <!-- iter 86: time-window filter ComboBox. SelectedValue uses
                                     SelectedValuePath="Tag" so the bound int? matches the Tag
                                     attribute (null = all, 1 = 1min, 5 = 5min). -->
                                <TextBlock Text="    Window: " Margin="12,0,0,0"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"/>
                                <ComboBox Width="120"
                                          SelectedValue="{Binding ActivityLogTimeWindowMinutes}"
                                          SelectedValuePath="Tag"
                                          VerticalAlignment="Center"
                                          ToolTip="Limit the table to entries received in the last N minutes. Useful for bug-repro windows.">
                                    <ComboBoxItem Content="All" IsSelected="True">
                                        <ComboBoxItem.Tag>
                                            <x:Null/>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="Last 5 min">
                                        <ComboBoxItem.Tag>
                                            <sys:Int32>5</sys:Int32>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="Last 1 min">
                                        <ComboBoxItem.Tag>
                                            <sys:Int32>1</sys:Int32>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                </ComboBox>
                                <!-- iter 66: substring filter on Lua command. Operator
                                     types "GodMode" → DataGrid narrows to that helper. -->
                                <TextBlock Text="    Filter: "
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"/>
                                <TextBox Width="180"
                                         Text="{Binding ActivityLogCommandFilter, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         ToolTip="Substring filter on the Lua command column (case-insensitive). Empty = no filter. Type 'GodMode' to see only SWFOC_GodMode calls."/>
                                <!-- iter 87: single-click reset for all three filters. -->
                                <Button Content="Reset filters"
                                        Command="{Binding ResetActivityLogFiltersCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Clear all activity log filters in one click — errors-only, time window, and substring filter all return to defaults. Useful after a bug-repro session."/>
                                <!-- iter 89: at-a-glance status line showing which filters are narrowing the view. -->
                                <TextBlock Text="{Binding ActiveFiltersDescription}"
                                           Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVisibility}}"
                                           Foreground="{DynamicResource WarningForeground}"
                                           FontStyle="Italic" FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           ToolTip="The activity log is currently narrowed by these filters. Click 'Reset filters' to widen back to the full ring buffer."/>
                                <Button Content="Copy to clipboard"
                                        Command="{Binding CopyActivityLogCommand}"
                                        Margin="12,0,0,0"
                                        ToolTip="Copy the currently-displayed rows as a TSV (timestamp / ok / ms / command / response). Suitable for pasting into bug reports."/>
                                <!-- iter 84: JSON sibling for automation/API/log-aggregator pipelines that don't parse TSV. -->
                                <Button Content="Copy as JSON"
                                        Command="{Binding CopyActivityLogJsonCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Copy the currently-displayed rows as a JSON array (each entry has timestamp/succeeded/durationMs/luaCommand/responseOrError). Useful for automation pipelines or LLM-review tooling that expects JSON input."/>
                                <!--
                                    2026-04-27 (iter 50): file sibling. Useful
                                    for cross-session bug reports or large
                                    captures that exceed the clipboard's
                                    practical size.
                                -->
                                <Button Content="Save to file…"
                                        Command="{Binding SaveActivityLogCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Save the currently-displayed rows as a TSV to a file via Save dialog. Default filename is timestamped."/>
                                <!-- iter 85: JSON file-export sibling. -->
                                <Button Content="Save as JSON…"
                                        Command="{Binding SaveActivityLogJsonCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Save the currently-displayed rows as a JSON file. Schema: array of {timestamp, succeeded, durationMs, luaCommand, responseOrError}. UTF-8, no BOM. Useful for offline analysis or feeding into automation pipelines."/>
                                <!-- iter 66: clear log button. Operator clicks before
                                     reproducing a bug to see only the suspect interaction. -->
                                <Button Content="Clear log"
                                        Command="{Binding ClearActivityLogCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Drop every entry in the activity ring buffer. Useful before reproducing a bug — click Clear, then click the suspect button to see only that interaction's calls."/>
                            </StackPanel>
                            <!--
                                2026-04-27 (iter 48): at-a-glance bridge-health
                                rollup. Updated whenever the underlying ring
                                buffer changes (Refresh tick OR ActivityRecorded
                                event from any bridge call).
                            -->
                            <TextBlock Text="{Binding ActivityStatsLine}"
                                       FontFamily="Consolas, Lucida Console, monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       ToolTip="Total calls in the ring buffer, success rate, average ms, and the most-called command this session."/>
                            <!--
                                2026-04-27 (iter 52): sortable + alternating
                                row background. CanUserSortColumns lets the
                                operator click headers to find the slowest
                                call (ms ↓), group identical commands, or
                                cluster failures (OK column). RowBackground
                                + AlternatingRowBackground improve readability
                                when the grid is dense; ClipboardCopyMode
                                enables Ctrl+C copy of selected rows
                                including the column headers (TSV by default).
                            -->
                            <DataGrid ItemsSource="{Binding RecentBridgeCalls}"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserSortColumns="True"
                                      ClipboardCopyMode="IncludeHeader"
                                      Background="{DynamicResource ChromeBackground}"
                                      Foreground="{DynamicResource TextForeground}"
                                      AlternatingRowBackground="{DynamicResource AltRowBackground}"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      MaxHeight="240">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="When" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="100"/>
                                    <DataGridTextColumn Header="OK" Binding="{Binding Succeeded}" Width="50"/>
                                    <!-- iter 65: ms column color-coded by duration bucket so slow
                                         calls pop visually. Binding flows through DurationCategoryToBrush
                                         which looks up DurationFastBrush / DurationNormalBrush /
                                         DurationSlowBrush / DurationVerySlowBrush in the active theme. -->
                                    <DataGridTextColumn Header="ms" Binding="{Binding DurationMs}" Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{Binding DurationCategory, Converter={StaticResource DurationCategoryToBrush}}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="ToolTip"
                                                        Value="{Binding DurationCategory, StringFormat='Duration bucket: {0} (Fast&lt;50, Normal&lt;200, Slow&lt;500, VerySlow&gt;=500)'}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Command" Binding="{Binding LuaCommand}" Width="240"/>
                                    <DataGridTextColumn Header="Response / Error" Binding="{Binding ResponseOrError}" Width="*"/>
                                </DataGrid.Columns>
                                <!-- iter 75: right-click context menu for pinning entries.
                                     Operators bookmark interesting calls so they survive
                                     ring rotation. CommandParameter passes the row's bound
                                     BridgeActivityEntry to the RelayCommand<T>. -->
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Pin entry"
                                                  Command="{Binding PlacementTarget.DataContext.PinActivityCommand, RelativeSource={RelativeSource Self}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource Self}}"/>
                                        <MenuItem Header="Unpin entry"
                                                  Command="{Binding PlacementTarget.DataContext.UnpinActivityCommand, RelativeSource={RelativeSource Self}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource Self}}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <!-- iter 74: group-by-command aggregation. Sibling
                         to the per-call DataGrid above; operators use this
                         to spot which helper dominated recent traffic
                         without scrolling the 50-row per-call list. -->
                    <Expander Grid.Row="6" Header="Calls grouped by command"
                              IsExpanded="False" Margin="0,8,0,0">
                        <DataGrid ItemsSource="{Binding RecentCallCommandSummaries}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  ClipboardCopyMode="IncludeHeader"
                                  AlternatingRowBackground="{DynamicResource AltRowBackground}"
                                  Background="{DynamicResource ChromeBackground}"
                                  Foreground="{DynamicResource TextForeground}"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="280"/>
                                <DataGridTextColumn Header="#" Binding="{Binding CallCount}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="OK"
                                                    Binding="{Binding SuccessRate, StringFormat={}{0:P0}}"
                                                    Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Avg ms"
                                                    Binding="{Binding AverageDurationMs, StringFormat={}{0:0.0}}"
                                                    Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Max ms" Binding="{Binding MaxDurationMs}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- iter 75: pinned activity entries. Operators bookmark
                         interesting calls via right-click context menu on the
                         per-call DataGrid above; pinned entries survive ring
                         rotation. Bounded at 50 to keep the UI compact. -->
                    <Expander Grid.Row="7" Header="{Binding PinnedBridgeCallsHeader}"
                              IsExpanded="False" Margin="0,8,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="Clear pinned"
                                        Command="{Binding ClearPinnedCommand}"
                                        ToolTip="Drop every pinned entry. Distinct from the 'Clear log' button — that one only clears the rolling buffer; this one clears bookmarks."/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding PinnedBridgeCalls}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      CanUserSortColumns="True"
                                      ClipboardCopyMode="IncludeHeader"
                                      AlternatingRowBackground="{DynamicResource AltRowBackground}"
                                      Background="{DynamicResource ChromeBackground}"
                                      Foreground="{DynamicResource TextForeground}"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="When" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="100"/>
                                    <DataGridTextColumn Header="OK" Binding="{Binding Succeeded}" Width="50"/>
                                    <DataGridTextColumn Header="ms" Binding="{Binding DurationMs}" Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{Binding DurationCategory, Converter={StaticResource DurationCategoryToBrush}}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Command" Binding="{Binding LuaCommand}" Width="240"/>
                                    <DataGridTextColumn Header="Response / Error" Binding="{Binding ResponseOrError}" Width="*"/>
                                </DataGrid.Columns>
                                <!-- iter 75: right-click to unpin. Same pattern as the recent-calls
                                     context menu but only the Unpin verb. -->
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Unpin entry"
                                                  Command="{Binding PlacementTarget.DataContext.UnpinActivityCommand, RelativeSource={RelativeSource Self}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource Self}}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 2: Player State -->
            <TabItem Header="Player State" ToolTip="{Binding TooltipPlayerState}">
                <Grid DataContext="{Binding PlayerState}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Player slot:" Margin="0,0,6,0"/>
                        <!-- 2026-04-25: 0..7 slots with display labels
                             ("Slot 6 — UNDERWORLD"). Using ItemTemplate
                             instead of DisplayMemberPath so the closed-
                             state TextBlock inherits the explicit light
                             foreground; the system theme overrides the
                             ComboBox-level Foreground for the closed
                             selection display, leaving it invisible
                             on dark backgrounds otherwise. -->
                        <!-- iter 319: extended ItemTemplate with faction emblem Image
                             next to DisplayLabel. IconPath null when no resolver
                             wired OR DDS not extracted — null binding hides the
                             Image gracefully (no broken-image placeholder).
                             Width bumped 240→280 to accommodate the icon column. -->
                        <ComboBox ItemsSource="{Binding Slots}"
                                  SelectedItem="{Binding SelectedSlotEntry}"
                                  TextSearch.TextPath="DisplayLabel"
                                  Width="280">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding IconPath}"
                                               Width="24" Height="24"
                                               Stretch="Uniform"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding FactionName}"/>
                                        <TextBlock Text="{Binding DisplayLabel}"
                                                   Foreground="{DynamicResource TextForeground}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="Refresh slot map" Command="{Binding RefreshSlotMapCommand}" Margin="10,0,0,0"
                                ToolTip="Read live faction names from SWFOC_GetAllPlayers and label each slot."/>
                        <Button Content="Detect local" Command="{Binding DetectLocalPlayerCommand}"/>
                        <Button Content="Switch to selected slot (v3 + AI swap)" Command="{Binding SwitchToSlotCommand}"
                                ToolTip="Direct slot-based faction switch via SWFOC_SetHumanPlayer_v3 — swaps AI brain pointers (+0x360) so the AI no longer drives the faction you switched to."/>
                        <Button Content="Null AI on selected slot" Command="{Binding NullAiBrainCommand}"
                                ToolTip="Sets PlayerObject+0x360 to null on the selected slot — frees that slot from AI control without moving brains."/>
                        <Button Content="Attach AI to selected slot" Command="{Binding AttachAiBrainCommand}"
                                ToolTip="Constructs a fresh AIPlayerClass for the selected slot via the engine's own ctor at RVA 0x4AF810."/>
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="Credits">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Amount:" Margin="0,0,6,0"/>
                            <TextBox Width="160" Text="{Binding CreditsInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Get" Command="{Binding GetCreditsCommand}" Margin="10,0,0,0"
                                    ToolTip="SWFOC_GetCredits → log the current credit count for the selected slot."/>
                            <Button Content="Set" Command="{Binding SetCreditsCommand}"
                                    ToolTip="SWFOC_SetCredits → write the Amount textbox value to the selected slot's credit pool."/>
                            <Button Content="Uncap" Command="{Binding UncapCreditsCommand}"
                                    ToolTip="SWFOC_UncapCredits → bumps the selected slot's MaxCredits to engine-max (~2.1B)."/>
                            <Button Content="Drain enemies" Command="{Binding DrainEnemyCreditsCommand}"
                                    ToolTip="SWFOC_DrainEnemyCredits → zeros the credit pool of every non-local slot."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="Tech level">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Level:" Margin="0,0,6,0"/>
                            <TextBox Width="60" Text="{Binding TechInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Get" Command="{Binding GetTechCommand}" Margin="10,0,0,0"
                                    ToolTip="SWFOC_GetTechLevel → log the selected slot's current tech tier."/>
                            <Button Content="Set" Command="{Binding SetTechCommand}"
                                    ToolTip="SWFOC_SetTechLevel → set the selected slot's tech tier (1..5 in vanilla; mods may extend the range)."/>
                        </StackPanel>
                    </GroupBox>

                    <!--
                        2026-04-27: removed the standalone "Switch faction"
                        button + Faction ComboBox + label. Both that button
                        and "Switch to selected slot (v3 + AI swap)" emit the
                        IDENTICAL Lua (SWFOC_SetHumanPlayer_v3). The slot-
                        based path is the authoritative one — it's what
                        actually swaps the AI brain pointer at +0x360 to
                        prevent the dual-control bug. The faction button
                        was a name->slot wrapper that added no engine
                        behaviour, so we drop it. Faction names are still
                        visible inline as "Slot 6 — UNDERWORLD" via the
                        Player slot dropdown's DisplayLabel, so the operator
                        loses no information.
                    -->
                    <GroupBox Grid.Row="3" Header="Heroes">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Respawn seconds:" Margin="0,0,6,0"/>
                            <TextBox Width="80" Text="{Binding RespawnSecondsInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Set respawn" Command="{Binding SetRespawnCommand}" Margin="10,0,0,0"
                                    ToolTip="SWFOC_SetHeroRespawn → set the global hero respawn default in seconds."/>
                            <Button Content="Instant respawn" Command="{Binding InstantRespawnCommand}"
                                    ToolTip="SWFOC_HeroInstantRespawn → force heroes to use the instant-respawn path."/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 2026-05-05 (iter 189): read-side native UX for iter-169
                         player-receiver wires. Operator types a player Lua expression
                         then clicks any of these to read engine state. Result lands
                         in the Bridge responses ListBox below. -->
                    <!-- 2026-05-07 (iter 378): UX polish — header was doubly stale at "Read-side (iter 169 + iter 199)":
                         (a) section now contains write-side wires too (Lock_Tech / Make_Ally / Make_Enemy /
                         Disable_Orbital_Bombardment / GLOBAL diplomacy), not just read-side; (b) iter-209
                         + iter-210 + iter-217 added 5 sub-batches the header didn't reflect. ~13 distinct
                         LIVE wires across iter 161/164/169/170/179/182/199/210/217. -->
                    <GroupBox Grid.Row="4" Header="Selected Player Actions (~13 LIVE wires; mixed read/write)">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Lua expression that resolves to a player handle. Examples: Find_Player(&quot;REBEL&quot;), Find_Player(&quot;EMPIRE&quot;), Get_Local_Player()."/>
                            <TextBox Text="{Binding PlayerLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"/>
                            <WrapPanel>
                                <Button Content="Read credits" Command="{Binding ReadPlayerCreditsLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Get_Credits(). Returns current credit balance via Bridge responses below. Read-after-write pair with PlayerGiveMoney."/>
                                <Button Content="Read tech level" Command="{Binding ReadPlayerTechLevelLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Get_Tech_Level(). Returns 1-5. Read-after-write pair with PlayerSetTechLevel."/>
                                <Button Content="Read faction" Command="{Binding ReadPlayerFactionLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Get_Faction(). Returns faction name string (REBEL / EMPIRE / UNDERWORLD)."/>
                                <!-- 2026-05-05 (iter 199): + 1 more no-arg button. -->
                                <Button Content="Read name" Command="{Binding ReadPlayerNameLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Get_Name(). Returns the player's display name (e.g. 'Rebel Alliance')."/>
                            </WrapPanel>
                            <!--
                                2026-05-05 (iter 199): predicate buttons for
                                iter-179 Is_Enemy / Is_Ally wires. Each takes a
                                second player Lua expression. Pairs with iter-178
                                GetLocalPlayer for "is THIS player my enemy?".
                            -->
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Other-player Lua: Is_Enemy / Is_Ally take a second player handle. Pairs with Get_Local_Player() for diplomacy probing."/>
                            <TextBox Text="{Binding OtherPlayerLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Is enemy of?" Command="{Binding IsEnemyLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Is_Enemy(other_player). Boolean predicate."/>
                                <Button Content="Is ally of?" Command="{Binding IsAllyLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Is_Ally(other_player). Boolean predicate. Pairs with Is_Enemy for full diplomacy probing."/>
                            </StackPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Diplomacy write-side: Make_Ally / Make_Enemy use the OtherPlayerLuaExpr field above (read + write share the same player). Lock_Tech needs a tech-name; uses the field below."/>
                            <TextBox Text="{Binding TechTypeLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Lock tech" Command="{Binding LockTechLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Lock_Tech(tech_name). Complement to PlayerUnlockTech. Uses TechTypeLuaExpr field for the tech-name arg."/>
                                <Button Content="Make ally" Command="{Binding MakeAllyLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Make_Ally(other_player). WARNING: state RESETS on Galactic↔Tactical mode change. Reuses Is_Enemy/Is_Ally OtherPlayerLuaExpr."/>
                                <Button Content="Make enemy" Command="{Binding MakeEnemyLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Make_Enemy(other_player). WARNING: state RESETS on Galactic↔Tactical mode change. Reuses Is_Enemy/Is_Ally OtherPlayerLuaExpr."/>
                            </StackPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="PlayerWrapper extension: Enable_As_Actor is no-arg (uses PlayerLuaExpr). Release_Credits_For_Tactical needs an amount; Select_Object needs an object handle (separate fields below)."/>
                            <TextBox Text="{Binding ReleaseCreditsAmount, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,4"
                                     ToolTip="Numeric amount for Release_Credits_For_Tactical (e.g. 50000)"/>
                            <TextBox Text="{Binding SelectObjectLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"
                                     ToolTip="Object Lua expression for Select_Object (e.g. Find_First_Object('AT_AT'))"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Enable as actor" Command="{Binding EnableAsActorLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Enable_As_Actor(). No-arg method. Enables AI actor mode for the player."/>
                                <Button Content="Release credits" Command="{Binding ReleaseCreditsForTacticalLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Release_Credits_For_Tactical(amount). Releases banked credits during galactic→tactical transition. Uses ReleaseCreditsAmount field."/>
                                <Button Content="Select object" Command="{Binding SelectObjectLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Select_Object(object). Programmatically selects a unit in the player's UI. Uses SelectObjectLuaExpr field."/>
                            </StackPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Player extensions: Disable_Orbital_Bombardment toggles per-player orbital bombardment via on/off pair (uses PlayerLuaExpr). GLOBAL Make_Ally / Make_Enemy are alternative diplomacy forms — both forms work in the engine; complement to obj-receiver Make_Ally / Make_Enemy. WARNING: state RESETS on Galactic↔Tactical mode change. Reuses PlayerLuaExpr (player1) + OtherPlayerLuaExpr (player2) — no new input fields."/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Disable orbital bombardment: on" Command="{Binding DisableOrbitalBombardmentOnLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Disable_Orbital_Bombardment(true). Hardcoded bool arg (on/off pair pattern). Uses PlayerLuaExpr field above."/>
                                <Button Content="Disable orbital bombardment: off" Command="{Binding DisableOrbitalBombardmentOffLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls (player):Disable_Orbital_Bombardment(false). Hardcoded bool arg (on/off pair pattern). Uses PlayerLuaExpr field above."/>
                                <Button Content="Make ally (GLOBAL)" Command="{Binding GlobalMakeAllyLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls Make_Ally(player1, player2) global form via Lua_DispatchGlobalArg2Method. Alternative to obj-receiver (player1):Make_Ally(player2). WARNING: state RESETS on Galactic↔Tactical mode change."/>
                                <Button Content="Make enemy (GLOBAL)" Command="{Binding GlobalMakeEnemyLuaCommand}" Margin="0,0,6,0"
                                        ToolTip="Calls Make_Enemy(player1, player2) global form via Lua_DispatchGlobalArg2Method. Alternative to obj-receiver Make_Enemy. WARNING: state RESETS on Galactic↔Tactical mode change."/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="5" Header="Bridge responses">
                        <ListBox ItemsSource="{Binding Output}"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 3: Unit Control -->
            <TabItem Header="Unit Control" ToolTip="{Binding TooltipUnitControl}">
                <Grid DataContext="{Binding UnitControl}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <!-- iter 117: Selected Unit Lua Actions row -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 2026-04-11: Unit selection row. Auto-use selected is ON by default
                         so the buttons act on whatever the user has clicked in-game. The
                         textbox stays live for power users who want to paste a specific
                         address returned by InspectUnit. -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Obj addr (hex):" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBox Width="180" Text="{Binding ObjAddrInput, UpdateSourceTrigger=PropertyChanged}" ToolTip="Absolute runtime address of the target GameObject. If 'Auto-use selected' is on, the buttons ignore this and resolve the current in-game selection instead."/>
                        <Button Content="Use selected" Command="{Binding UseSelectedCommand}" Margin="8,0,0,0" ToolTip="Query SWFOC_GetSelectedUnit() and write the pointer into the textbox above."/>
                        <CheckBox Content="Auto-use selected" IsChecked="{Binding AutoUseSelected}" Margin="18,0,0,0" VerticalAlignment="Center" ToolTip="When checked, every per-unit button resolves the current in-game selection at click time and ignores the textbox."/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Selected:" Margin="0,0,6,0" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedUnitSummary, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="420" ToolTip="Summary of the last unit read via SWFOC_GetSelectedUnit + SWFOC_InspectUnit."/>
                        <Button Content="Refresh" Command="{Binding RefreshSelectionCommand}" Margin="8,0,0,0" ToolTip="Re-read the current selection and refresh the summary label."/>
                    </StackPanel>

                    <GroupBox Grid.Row="2" Header="God mode / one hit kill">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="God mode ON" Command="{Binding EnableGodModeCommand}"
                                    ToolTip="Toggle god mode for the selected unit (or auto-use selection). Hull damage is suppressed at the engine level."/>
                            <Button Content="God mode OFF" Command="{Binding DisableGodModeCommand}"
                                    ToolTip="Disable god mode for the selected unit."/>
                            <Button Content="One hit kill ON" Command="{Binding EnableOneHitKillCommand}" Margin="18,0,0,0"
                                    ToolTip="Outgoing damage from the selected unit is amplified to one-shot any target."/>
                            <Button Content="One hit kill OFF" Command="{Binding DisableOneHitKillCommand}"
                                    ToolTip="Restore normal outgoing damage."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="3" Header="Per-unit">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Hull HP:" Margin="0,0,6,0"/>
                                <TextBox Width="120" Text="{Binding HullHpInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Set hull" Command="{Binding SetUnitHullCommand}" Margin="8,0,0,0"
                                        ToolTip="SWFOC_SetUnitHull → write the Hull HP value to the selected unit's hull field. Lua 5.0 only — values must be decimal (no 0x prefix)."/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Unit invuln ON" Command="{Binding EnableUnitInvulnCommand}"
                                        ToolTip="SWFOC_SetUnitInvuln(addr,1) → set the engine's invuln flag for this unit only."/>
                                <Button Content="Unit invuln OFF" Command="{Binding DisableUnitInvulnCommand}"
                                        ToolTip="SWFOC_SetUnitInvuln(addr,0) → clear the invuln flag."/>
                                <Button Content="Prevent death ON" Command="{Binding EnablePreventDeathCommand}" Margin="18,0,0,0"
                                        ToolTip="SWFOC_PreventUnitDeath(addr,1) → bit-flip the prevent-death byte. Engine clamps the unit to 1 HP instead of dying."/>
                                <Button Content="Prevent death OFF" Command="{Binding DisablePreventDeathCommand}"
                                        ToolTip="SWFOC_PreventUnitDeath(addr,0) → clear the prevent-death bit."/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="4" Header="Inspect">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Inspect unit" Command="{Binding InspectUnitCommand}"
                                    ToolTip="SWFOC_InspectUnit → log a key=value snapshot of the unit's runtime state to the output panel below."/>
                            <Button Content="Get hardpoints" Command="{Binding GetHardpointsCommand}"
                                    ToolTip="SWFOC_GetHardpoints → enumerate the unit's attached hardpoints and their state."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="5" Header="Spawn unit">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Unit id:" Margin="0,0,6,0"/>
                            <TextBox Width="200" Text="{Binding SpawnUnitId, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text=" Faction:" Margin="12,0,6,0"/>
                            <ComboBox ItemsSource="{Binding Factions}" SelectedItem="{Binding SpawnFaction}" Width="130"/>
                            <TextBlock Text=" Count:" Margin="12,0,6,0"/>
                            <TextBox Width="60" Text="{Binding SpawnCount, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Spawn" Command="{Binding SpawnUnitCommand}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="6" Header="Last inspect / hardpoint result">
                        <TextBox Text="{Binding LastInspectOrHardpoint, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="60"/>
                    </GroupBox>

                    <!-- 2026-04-28 (iter 117) LIVE: per-unit Lua-method actions
                         shipped iter 110-112. Operator types a unit Lua expression
                         (Find_First_Object("Empire_AT_AT")) into the TextBox; every
                         button below fires the matching SWFOC_<X>UnitLua engine call.
                         Sibling row to the existing "Per-unit" GroupBox above —
                         that block uses obj_addr (decimal); this block uses Lua
                         expressions (handle-by-name). Both are valid; Lua
                         expressions work in galactic mode where addrs aren't
                         enumerable, while addrs work for selection-driven flows. -->
                    <!-- 2026-05-07 (iter 377): UX polish — header was stale at "(iter 117-118 LIVE)"
                         despite the section growing through 8 sub-batches over iter 110-218
                         (~24 distinct LIVE wires). Operators see the full per-button capability
                         badges + tooltips below; the header just says how many actions live here. -->
                    <GroupBox Grid.Row="7" Header="Selected Unit Lua Actions (~24 LIVE wires; see per-button badges)">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Lua expression that resolves to a unit handle. Examples: Find_First_Object(&quot;Empire_AT_AT&quot;), Find_Object_Type(&quot;Rebel_Trooper_Squad&quot;)[0], Find_Hint(&quot;hero&quot;)."/>
                            <TextBox Text="{Binding SelectedUnitLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"/>
                            <WrapPanel>
                                <Button Content="Make invuln ON" Command="{Binding EnableMakeInvulnLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Make_Invulnerable(true) via DoString. Propagates to all hardpoints."/>
                                <Button Content="Make invuln OFF" Command="{Binding DisableMakeInvulnLuaCommand}" Margin="0,0,18,4"
                                        ToolTip="Calls (unit):Make_Invulnerable(false)."/>
                                <Button Content="Hide ON" Command="{Binding EnableHideUnitLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Hide(true). Visibility toggle, doesn't despawn."/>
                                <Button Content="Hide OFF" Command="{Binding DisableHideUnitLuaCommand}" Margin="0,0,18,4"
                                        ToolTip="Calls (unit):Hide(false)."/>
                                <Button Content="Lock from AI" Command="{Binding EnablePreventAiUsageLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Prevent_AI_Usage(true). AI can't issue orders to this unit."/>
                                <Button Content="Unlock to AI" Command="{Binding DisablePreventAiUsageLuaCommand}" Margin="0,0,18,4"
                                        ToolTip="Calls (unit):Prevent_AI_Usage(false)."/>
                                <Button Content="Selectable ON" Command="{Binding EnableSelectableLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Set_Selectable(true)."/>
                                <Button Content="Selectable OFF" Command="{Binding DisableSelectableLuaCommand}" Margin="0,0,18,4"
                                        ToolTip="Calls (unit):Set_Selectable(false). Operator can't click-select."/>
                                <Button Content="Despawn" Command="{Binding DespawnUnitLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Despawn(). Removes the unit cleanly."/>
                                <Button Content="Stop" Command="{Binding StopUnitLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Stop(). Interrupts current order."/>
                                <Button Content="Retreat" Command="{Binding RetreatUnitLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Retreat(). Engine flees the unit."/>
                                <!-- 2026-05-05 (iter 188): read-side native UX. Result lands in
                                     the Bridge responses ListBox below (engine returns the value
                                     as a string via DoString return-stack capture). -->
                                <Button Content="Read hull" Command="{Binding ReadUnitHullLuaCommand}" Margin="18,0,6,4"
                                        ToolTip="Calls (unit):Get_Hull(). Returns current HP as a float in the Bridge responses below."/>
                                <Button Content="Read shield" Command="{Binding ReadUnitShieldLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Get_Shield(). Returns shield percentage."/>
                                <Button Content="Read position" Command="{Binding ReadUnitPositionLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Get_Position(). Returns position table handle."/>
                                <Button Content="Read garrison" Command="{Binding ReadUnitGarrisonLuaCommand}" Margin="0,0,6,4"
                                        ToolTip="Calls (unit):Get_Garrison_Units(). Returns garrison list (table handle for Lua iteration)."/>
                            </WrapPanel>

                            <!-- iter 118 (2026-04-29): Change Unit Owner — same SelectedUnitLuaExpr,
                                 needs an additional Lua expression for the destination player. -->
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Change owner: target player Lua expression. Examples: Find_Player(&quot;REBEL&quot;), Find_Player(&quot;Hostile_Garrison&quot;)."/>
                            <TextBox Text="{Binding TargetPlayerLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"/>
                            <Button Content="Change unit owner →"
                                    Command="{Binding ChangeUnitOwnerLuaCommand}"
                                    HorizontalAlignment="Left" Padding="12,4"
                                    ToolTip="Calls SWFOC_ChangeUnitOwner(unitExpr, playerExpr) via DoString. Engine reassigns ownership; visual asset reskins to the new player's faction colors."/>

                            <!--
                                2026-05-05 (iter 194): combat-order extension.
                                Surfaces iter-163 LIVE wires (Attack_Target, Guard_Target,
                                Divert) reusing the SelectedUnitLuaExpr above + a new
                                shared TargetForCombatOrderLuaExpr for the target unit
                                (Attack/Guard) or position (Divert).
                            -->
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Combat orders: target unit Lua expression for Attack / Guard, or position handle for Divert. Examples: Find_First_Object(&quot;Rebel_Tank&quot;), (Find_First_Object(&quot;Empire_AT_AT&quot;)):Get_Position()."/>
                            <TextBox Text="{Binding TargetForCombatOrderLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"/>
                            <WrapPanel>
                                <Button Content="Attack target"
                                        Command="{Binding AttackTargetLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Attack_Target(target). Orders the selected unit to attack the target unit."/>
                                <TextBlock Text="{Binding AttackTargetLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding AttackTargetLuaAction.Tooltip}"/>
                                <Button Content="Guard target"
                                        Command="{Binding GuardTargetLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Guard_Target(target). Defensive escort — selected unit will guard the target unit."/>
                                <TextBlock Text="{Binding GuardTargetLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding GuardTargetLuaAction.Tooltip}"/>
                                <Button Content="Divert to position"
                                        Command="{Binding DivertLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Divert(position). Diverts the selected unit's current path to the given position handle."/>
                                <TextBlock Text="{Binding DivertLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding DivertLuaAction.Tooltip}"/>
                            </WrapPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Unit-method extension: Activate_Ability needs an ability-name (field below); Disable_Capture / Set_Garrison_Spawn use hardcoded bool args via on/off pair buttons; Cancel_Hyperspace is no-arg. All anchor on SelectedUnitLuaExpr."/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding AbilityNameLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas, Lucida Console, monospace"
                                         ToolTip="Ability-name Lua expression for Activate_Ability (e.g. &quot;Tractor_Beam&quot;). Use the dropdown to pick a known ability name, or type your own custom Lua expression."/>
                                <ComboBox Grid.Column="1"
                                          Width="200" Margin="6,0,0,0"
                                          ItemsSource="{x:Static diag:KnownUnitAbilityNames.All}"
                                          SelectedItem="{Binding AbilityNamePresetSelection}"
                                          ToolTip="Pick from 69 known unit-ability names (recovered from EnumConversionClass&lt;UnitAbilityType&gt; static initializer). Selecting populates the field at left with the quoted Lua-string form."/>
                            </Grid>
                            <WrapPanel>
                                <Button Content="Activate ability"
                                        Command="{Binding ActivateAbilityLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Activate_Ability(name). Uses AbilityNameLuaExpr field for the ability-name string arg."/>
                                <TextBlock Text="{Binding ActivateAbilityLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Disable capture: on"
                                        Command="{Binding DisableCaptureOnLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Disable_Capture(true). Prevents the unit from being captured at low HP."/>
                                <Button Content="Disable capture: off"
                                        Command="{Binding DisableCaptureOffLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Disable_Capture(false). Re-enables capture at low HP."/>
                                <TextBlock Text="{Binding DisableCaptureOnLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Garrison spawn: on"
                                        Command="{Binding SetGarrisonSpawnOnLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_Garrison_Spawn(true). Toggles whether the unit produces garrison units."/>
                                <Button Content="Garrison spawn: off"
                                        Command="{Binding SetGarrisonSpawnOffLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_Garrison_Spawn(false). Disables garrison-unit production."/>
                                <TextBlock Text="{Binding SetGarrisonSpawnOnLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Cancel hyperspace"
                                        Command="{Binding CancelHyperspaceLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Cancel_Hyperspace(). No-arg. Cancels an in-progress hyperspace jump."/>
                                <TextBlock Text="{Binding CancelHyperspaceLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Unit-method mega-batch: Set_In_Limbo + Set_Check_Contested_Space use hardcoded-bool on/off pair buttons. Sell is no-arg. Bribe reuses TargetPlayerLuaExpr (target player to switch the unit's allegiance to). Move_To reuses TargetForCombatOrderLuaExpr (semantically same 'where to go' as Divert). Fire_Special_Weapon needs slot (field below)."/>
                            <TextBox Text="{Binding SpecialWeaponSlotLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"
                                     ToolTip="Slot Lua expression for Fire_Special_Weapon (e.g. &quot;0&quot; or &quot;1&quot;)"/>
                            <WrapPanel>
                                <Button Content="Set in limbo: on"
                                        Command="{Binding SetInLimboOnLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_In_Limbo(true). Removes the unit from active gameplay (paused state)."/>
                                <Button Content="Set in limbo: off"
                                        Command="{Binding SetInLimboOffLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_In_Limbo(false). Restores the unit to active gameplay."/>
                                <TextBlock Text="{Binding SetInLimboOnLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Check contested: on"
                                        Command="{Binding SetCheckContestedSpaceOnLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_Check_Contested_Space(true). Enables contested-space detection on the unit."/>
                                <Button Content="Check contested: off"
                                        Command="{Binding SetCheckContestedSpaceOffLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_Check_Contested_Space(false). Disables contested-space detection."/>
                                <TextBlock Text="{Binding SetCheckContestedSpaceOnLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Sell unit"
                                        Command="{Binding SellUnitLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Sell(). No-arg. Sells the unit for credits."/>
                                <TextBlock Text="{Binding SellUnitLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Bribe unit"
                                        Command="{Binding BribeLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Bribe(player). Underworld signature ability — corrupts unit to switch sides for credits. Reuses Change-owner TargetPlayerLuaExpr."/>
                                <TextBlock Text="{Binding BribeLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Move to position"
                                        Command="{Binding MoveToLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Move_To(position). Orders unit to move to a position. Reuses Combat-order TargetForCombatOrderLuaExpr (same 'where to go' semantic as Divert)."/>
                                <TextBlock Text="{Binding MoveToLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Fire special weapon"
                                        Command="{Binding FireSpecialWeaponLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Fire_Special_Weapon(slot). Fires the unit's special weapon at the given slot index. Uses SpecialWeaponSlotLuaExpr field."/>
                                <TextBlock Text="{Binding FireSpecialWeaponLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Unit-method bool batch: Set_Cannot_Be_Killed + Enable_Stealth use hardcoded-bool on/off pair buttons. Override_Max_Speed is per-unit float (complements the global SetPerFactionSpeedMultiplier on the Speed tab)."/>
                            <TextBox Text="{Binding MaxSpeedOverrideLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"
                                     ToolTip="Numeric speed Lua expression for Override_Max_Speed (e.g. &quot;100.0&quot;)"/>
                            <WrapPanel>
                                <Button Content="Cannot be killed: on"
                                        Command="{Binding SetCannotBeKilledOnLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_Cannot_Be_Killed(true). Soft-invuln (unit can take damage but won't die)."/>
                                <Button Content="Cannot be killed: off"
                                        Command="{Binding SetCannotBeKilledOffLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Set_Cannot_Be_Killed(false). Re-enables death."/>
                                <TextBlock Text="{Binding SetCannotBeKilledOnLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Enable stealth: on"
                                        Command="{Binding EnableStealthOnLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Enable_Stealth(true). Activates stealth/cloak on the unit."/>
                                <Button Content="Enable stealth: off"
                                        Command="{Binding EnableStealthOffLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Enable_Stealth(false). Disables stealth/cloak."/>
                                <TextBlock Text="{Binding EnableStealthOnLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Override max speed"
                                        Command="{Binding OverrideMaxSpeedLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Override_Max_Speed(speed). Per-unit speed override; complements SetPerFactionSpeedMultiplier global. Uses MaxSpeedOverrideLuaExpr field."/>
                                <TextBlock Text="{Binding OverrideMaxSpeedLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Underworld signature ability: Corrupt degrades unit hostility/loyalty without taking ownership — pairs semantically with Bribe (which takes ownership). Uses SelectedUnitLuaExpr above + new CorruptAmountLuaExpr field below for numeric amount."/>
                            <TextBox Text="{Binding CorruptAmountLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"
                                     ToolTip="Numeric amount for Corrupt (e.g. 50)"/>
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Corrupt unit"
                                        Command="{Binding CorruptLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Corrupt(amount). Underworld faction signature ability — degrades unit hostility/loyalty. Pairs with Bribe (Bribe takes ownership; Corrupt degrades only). Uses CorruptAmountLuaExpr field."/>
                                <TextBlock Text="{Binding CorruptLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="8" Header="Bridge responses">
                        <ListBox ItemsSource="{Binding Output}"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 4: World State -->
            <TabItem Header="World State" ToolTip="{Binding TooltipWorldState}">
                <Grid DataContext="{Binding WorldState}" Margin="12">
                    <!-- 2026-05-07 (iter 461): added Row 4 (Trigger Victory) between
                         the row 3 Cinematic & Audio cluster and the existing Dump state +
                         Bridge responses. Dump state bumped from 4 → 5; Bridge responses
                         from 5 → 6. -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Corruption">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Planet id:" Margin="0,0,6,0"/>
                            <TextBox Width="160" Text="{Binding PlanetIdInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text=" Type:" Margin="12,0,6,0"/>
                            <ComboBox ItemsSource="{Binding CorruptionTypes}" SelectedItem="{Binding SelectedCorruptionType}" Width="150"/>
                            <TextBlock Text=" Level:" Margin="12,0,6,0"/>
                            <TextBox Width="60" Text="{Binding CorruptionLevelInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Set" Command="{Binding SetCorruptionCommand}" Margin="12,0,0,0"
                                    ToolTip="Set the chosen corruption type (Racketeering / Rebellion / Black-market) on the planet to the given level."/>
                            <Button Content="Remove" Command="{Binding RemoveCorruptionCommand}"
                                    ToolTip="Clear all corruption from the named planet."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="Diplomacy">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Faction A:" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding Factions}" SelectedItem="{Binding FactionA}" Width="130"/>
                            <TextBlock Text=" Faction B:" Margin="12,0,6,0"/>
                            <ComboBox ItemsSource="{Binding Factions}" SelectedItem="{Binding FactionB}" Width="130"/>
                            <TextBlock Text=" Relation:" Margin="12,0,6,0"/>
                            <ComboBox ItemsSource="{Binding DiplomacyRelations}" SelectedItem="{Binding SelectedDiplomacyRelation}" Width="120"/>
                            <Button Content="Apply" Command="{Binding SetDiplomacyCommand}" Margin="12,0,0,0"
                                    ToolTip="Set the relation between Faction A and Faction B (Allied / Hostile / Neutral / etc.). Galactic mode only."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="Story events and maphack">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Event id:" Margin="0,0,6,0"/>
                            <!--
                                2026-04-27: editable ComboBox so the operator
                                gets autocomplete on common diagnostic events
                                (STORY_TEST_EVENT, EVENT_GAME_WON, …). Mod
                                events still work — IsEditable=True lets the
                                operator type any string.
                            -->
                            <ComboBox Width="240"
                                      IsEditable="True"
                                      ItemsSource="{Binding StoryEventSuggestions}"
                                      Text="{Binding StoryEventId, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="Pick a suggestion or type a custom event id (mod-defined events still work)."/>
                            <Button Content="Fire event" Command="{Binding FireStoryEventCommand}" Margin="8,0,0,0"
                                    ToolTip="Call Story_Event(name) so the engine triggers the named campaign event (cinematic / mission objective / etc.)."/>
                            <CheckBox Content="Maphack state" IsChecked="{Binding MaphackEnabled}" Margin="24,0,0,0" IsHitTestVisible="False"/>
                            <Button Content="Toggle maphack" Command="{Binding ToggleMaphackCommand}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!--
                        2026-05-05 (iter 201): native UX surface for the
                        iter-159 string-arg global wires. Distinct from the
                        upper "Fire event" button (which routes through
                        IStoryEventService — catalog/profile-mediated). These
                        4 buttons hit the engine Lua API directly via
                        SWFOC_StoryEventLua / SWFOC_AddObjectiveLua /
                        SWFOC_PlayMusicLua / SWFOC_PlaySfxEventLua. All four
                        share a single name input. Story_Event/Add_Objective
                        share row 1; Play_Music/Play_SFX_Event share row 2.
                    -->
                    <!-- 2026-05-07 (iter 379): UX polish — header was stale at "Story & Audio (iter 159)";
                         section grew through 4 sub-batches (iter-201 + iter-202 + iter-204 + iter-208)
                         spanning iter 159/160/166/180/181 wires. Renamed to reflect actual scope —
                         it's now Cinematic & Audio (input lock + music + SFX + story/objective). -->
                    <GroupBox Grid.Row="3" Header="Cinematic &amp; Audio Controls (12 LIVE wires)" Margin="0,8,0,0">
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Name (Lua string): " VerticalAlignment="Center"/>
                                <TextBox Width="260" Text="{Binding StoryAudioNameLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Story event id, objective id, music event, or SFX event name. Same field is used by all four buttons below."/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Story_Event" Command="{Binding StoryEventLuaCommand}"
                                            ToolTip="SWFOC_StoryEventLua → engine Lua Story_Event(name). LIVE — fires a named story event. Distinct from the upper 'Fire event' button (catalog-mediated)."/>
                                    <TextBlock Text="{Binding StoryEventLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding StoryEventLua.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Add_Objective" Command="{Binding AddObjectiveLuaCommand}"
                                            ToolTip="SWFOC_AddObjectiveLua → engine Lua Add_Objective(id). LIVE — adds an objective to the player UI tracker."/>
                                    <TextBlock Text="{Binding AddObjectiveLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding AddObjectiveLua.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Play_Music" Command="{Binding PlayMusicLuaCommand}"
                                            ToolTip="SWFOC_PlayMusicLua → engine Lua Play_Music(event). LIVE — plays a named music event. Pairs with cinematic camera primitives for filming workflows."/>
                                    <TextBlock Text="{Binding PlayMusicLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding PlayMusicLua.Tooltip}"/>
                                </StackPanel>
                                <StackPanel>
                                    <Button Content="Play_SFX_Event" Command="{Binding PlaySfxEventLuaCommand}"
                                            ToolTip="SWFOC_PlaySfxEventLua → engine Lua Play_SFX_Event(event). LIVE — plays a named sound effect."/>
                                    <TextBlock Text="{Binding PlaySfxEventLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding PlaySfxEventLua.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                            <!--
                                2026-05-05 (iter 202): audio controls + story-trigger
                                extension. Stop/Resume Music are no-arg (no input
                                needed); Story_Event_Trigger reuses the shared name
                                input. Sits below the iter-201 row to keep the
                                "operator types name once, fires multiple actions"
                                workflow intact.
                            -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Stop_All_Music" Command="{Binding StopAllMusicLuaCommand}"
                                            ToolTip="SWFOC_StopAllMusicLua → engine Lua Stop_All_Music(). LIVE no-arg — silences all currently playing music. Pair with Play_Music to swap soundtracks during cinematics."/>
                                    <TextBlock Text="{Binding StopAllMusicLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding StopAllMusicLua.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Resume_Mode_Based_Music" Command="{Binding ResumeModeBasedMusicLuaCommand}"
                                            ToolTip="SWFOC_ResumeModeBasedMusicLua → engine Lua Resume_Mode_Based_Music(). LIVE no-arg — restores the default game-mode music after a cinematic Stop/Play override."/>
                                    <TextBlock Text="{Binding ResumeModeBasedMusicLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ResumeModeBasedMusicLua.Tooltip}"/>
                                </StackPanel>
                                <StackPanel>
                                    <Button Content="Story_Event_Trigger" Command="{Binding StoryEventTriggerLuaCommand}"
                                            ToolTip="SWFOC_StoryEventTriggerLua → engine Lua Story_Event_Trigger(name). LIVE — variant of Story_Event with different engine-side dispatch semantics. Uses the shared name field above."/>
                                    <TextBlock Text="{Binding StoryEventTriggerLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding StoryEventTriggerLua.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                            <!--
                                2026-05-05 (iter 204): SFX VO toggle from
                                iter-181. **PRESERVES ENGINE TYPO "Reponse"**
                                verbatim — docs section 6 confirms the
                                misspelling. Catalog rationale + iter-181
                                tests + iter-204 tests pin this so future
                                edits don't "correct" it.
                            -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="SFX VO toggle: " VerticalAlignment="Center"/>
                                <StackPanel Margin="6,0,0,0">
                                    <Button Content="VO on" Command="{Binding SfxAllowUnitReponseVoOnCommand}"
                                            ToolTip="SWFOC_SFXAllowUnitReponseVoLua(1) → SFXManager.Allow_Unit_Reponse_VO(true). LIVE no-input — re-enables per-unit voice-over response to player commands. Engine misspelling 'Reponse' preserved verbatim."/>
                                    <TextBlock Text="{Binding SfxAllowUnitReponseVoOn.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SfxAllowUnitReponseVoOn.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <Button Content="VO off" Command="{Binding SfxAllowUnitReponseVoOffCommand}"
                                            ToolTip="SWFOC_SFXAllowUnitReponseVoLua(0) → SFXManager.Allow_Unit_Reponse_VO(false). LIVE no-input — silences per-unit voice-over. Useful for cinematic recording."/>
                                    <TextBlock Text="{Binding SfxAllowUnitReponseVoOff.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SfxAllowUnitReponseVoOff.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                            <!--
                                2026-05-05 (iter 208): cinematic input-lock pair.
                                iter-160 Lock_Controls(bool) → 2 buttons (lock-on
                                / lock-off, hardcoded args). iter-180 Unlock_Controls()
                                → 1 button (no-arg). Pair-completion across two
                                iter shapes; cinematic-recording workflow gates
                                operator input then restores it.
                            -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Cinematic input lock: " VerticalAlignment="Center"/>
                                <StackPanel Margin="6,0,0,0">
                                    <Button Content="Lock on" Command="{Binding LockControlsOnCommand}"
                                            ToolTip="SWFOC_LockControlsLua(1) → Lock_Controls(true). LIVE — disables operator/player input (mouse, keyboard, gamepad) for the duration. Used by the engine's own cinematic system."/>
                                    <TextBlock Text="{Binding LockControlsOn.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding LockControlsOn.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <Button Content="Lock off" Command="{Binding LockControlsOffCommand}"
                                            ToolTip="SWFOC_LockControlsLua(0) → Lock_Controls(false). LIVE — re-enables operator/player input. Engine-canonical bool form."/>
                                    <TextBlock Text="{Binding LockControlsOff.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding LockControlsOff.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <Button Content="Unlock_Controls" Command="{Binding UnlockControlsLuaCommand}"
                                            ToolTip="SWFOC_UnlockControlsLua → Unlock_Controls(). LIVE no-arg — engine variant of Lock(false). Use when LockControls(0) doesn't restore input cleanly. Per docs/lua-api.md section 5.2."/>
                                    <TextBlock Text="{Binding UnlockControlsLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding UnlockControlsLua.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!--
                        2026-05-07 (iter 461): SWFOC_TriggerVictory native UX surface for the
                        iter-450 DORMANT MinHook scaffolding. The bridge wrapper validates
                        input against a 14-name allow-list (kKnownVictoryTypes in
                        lua_bridge.cpp); same list is mirrored in WorldState VM
                        VictoryTypes ObservableCollection + simulator s_knownVictoryTypes[]
                        + Lua Playground iter-452 presets (triple-source consistency
                        audited iter-459). PHASE 2 PENDING badge surfaces the dormant-
                        hook state — operator presses Trigger and sees the bridge accept
                        the call but engine state remains unchanged until iter-450c+
                        flips MH_EnableHook.
                    -->
                    <GroupBox Grid.Row="4" Header="Engine: Trigger Victory (PHASE 2 PENDING)" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Victory type: " VerticalAlignment="Center"/>
                            <ComboBox Width="240"
                                      ItemsSource="{Binding VictoryTypes}"
                                      SelectedItem="{Binding SelectedVictoryType}"
                                      ToolTip="Pick from the 14-name allow-list validated by the bridge wrapper. Names from VictoryMonitorClass / AwaitingVictoryTestType engine subsystem; mirrored across bridge + simulator + Lua Playground."/>
                            <StackPanel Margin="8,0,0,0">
                                <Button Content="Trigger" Command="{Binding TriggerVictoryLuaCommand}" MinWidth="80"
                                        ToolTip="Disabled: SWFOC_TriggerVictory is PHASE 2 PENDING. The bridge validates the selected victory type, but the engine-side victory injection hook is not active yet."/>
                                <TextBlock Text="{Binding TriggerVictoryLua.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding TriggerVictoryLua.Tooltip}"/>
                            </StackPanel>
                            <TextBlock Text="  Wire: return SWFOC_TriggerVictory('&lt;type&gt;')"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{DynamicResource MutedForeground}" FontSize="10"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="5" Header="Dump state">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Dump snapshot..." Command="{Binding DumpStateCommand}" MinWidth="160"
                                    ToolTip="Write a SWFOCSNAPv2 binary snapshot of the current world state to disk for offline replay analysis."/>
                            <TextBlock Text="  Writes SWFOC_DumpState(path) to a user-chosen file." Foreground="{DynamicResource MutedForeground}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="6" Header="Bridge responses">
                        <ListBox ItemsSource="{Binding Output}"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 5: Probes & Scripts -->
            <TabItem Header="Probes &amp; Scripts" ToolTip="{Binding TooltipProbes}">
                <Grid DataContext="{Binding Probes}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Canned recipe:" Margin="0,0,6,0"/>
                        <ComboBox ItemsSource="{Binding Recipes}" SelectedItem="{Binding SelectedRecipe}" Width="360"/>
                        <Button Content="Load" Command="{Binding LoadRecipeCommand}" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!--
                        2026-04-27 (iter 21): recent-commands ring. The operator
                        types one probe, observes the response, and almost
                        always wants to resend a TWEAKED variant. Without
                        history they had to copy-paste from the output log
                        (which truncates at 40 lines). This bar gives them a
                        most-recent-first dropdown of the last 20 sends and a
                        "Recall" button that loads the chosen entry back into
                        the editor. Bounded; ephemeral; not persisted.
                    -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Recent:" Margin="0,0,6,0"/>
                        <ComboBox ItemsSource="{Binding History}" SelectedItem="{Binding SelectedHistory}" Width="360"
                                  ToolTip="Most-recent-first ring of Lua snippets sent this session (max 20). Picking + Recall pulls the entry back into the input above so you can tweak and resend."/>
                        <Button Content="Recall" Command="{Binding RecallSelectedHistoryCommand}" Margin="8,0,0,0"
                                ToolTip="Load the selected recent command back into the Lua input box."/>
                        <Button Content="Clear history" Command="{Binding ClearHistoryCommand}" Margin="6,0,0,0"
                                ToolTip="Wipe the recent-commands ring (does not affect saved recipes)."/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Lua input:" Margin="0,4,0,4"/>

                    <TextBox Grid.Row="3"
                             Text="{Binding LuaInput, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Lucida Console, monospace"
                             FontSize="12"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,6">
                        <Button Content="Send" Command="{Binding SendCommand}" MinWidth="120"
                                ToolTip="Forward the textbox content to the bridge pipe and append the round-trip result to the output panel below."/>
                        <TextBlock Text=" Save as recipe:" Margin="16,0,6,0"/>
                        <TextBox Width="220" Text="{Binding SaveRecipeNameInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Save" Command="{Binding SaveRecipeCommand}" Margin="6,0,0,0"/>
                        <!--
                            2026-04-27: clipboard + clear shortcuts. Output
                            log fills with "[ok]" / "[err]" / "> probe"
                            lines; operators want one-click capture for
                            bug reports and a fast wipe between probes.
                        -->
                        <Button Content="Copy output"
                                Command="{Binding CopyOutputCommand}"
                                Margin="16,0,0,0"
                                ToolTip="Copy the entire output log (last 40 lines) to the clipboard."/>
                        <Button Content="Clear"
                                Command="{Binding ClearOutputCommand}"
                                Margin="6,0,0,0"
                                ToolTip="Wipe the output log."/>
                    </StackPanel>

                    <GroupBox Grid.Row="5" Header="Output (last 40)">
                        <ListBox ItemsSource="{Binding Output}"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 6: Settings -->
            <TabItem Header="Settings">
                <Grid DataContext="{Binding Settings}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <!-- 2026-05-07 (iter 303): iter-301 VM mod-picker takes
                             the * row so the DataGrid expands as the window
                             resizes. Operator can refresh the mod list, see what's
                             currently loaded, and open the Mods/ folder for the
                             iter-297 stub-mod sidecar workflow. -->
                        <RowDefinition Height="*"/>
                        <!-- 2026-05-07 (iter 310, Thread D arc post-finale): the
                             iter-309 IconsRoot setting needs an operator-clickable
                             surface. Sits below the mod picker as a compact strip
                             (Height=Auto) so it doesn't fight the mod DataGrid for
                             vertical space. -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!--
                        2026-04-27: live path-validation badges next to the
                        path TextBlocks. GamePathStatus / LogPathStatus
                        return empty for valid paths (so the badge collapses)
                        and a short reason ("(file not found)") otherwise —
                        catches "I copied the binary to the wrong place"
                        before the operator launches the game.
                    -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2,0,2">
                        <TextBlock Text="Game path"/>
                        <TextBlock Text="{Binding GamePathStatus}"
                                   Foreground="{DynamicResource WarningForeground}"
                                   Margin="8,0,0,0" FontStyle="Italic"/>
                    </StackPanel>
                    <!--
                        2026-04-27: Browse buttons. OpenFileDialog handles
                        the path entry so the operator doesn't have to type
                        long Steam install paths. The text input remains
                        editable for power-users.
                    -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Command="{Binding BrowseGamePathCommand}"
                                Margin="6,0,0,0"
                                ToolTip="Open a file picker to locate StarWarsG.exe."/>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Bridge pipe name (without \\.\pipe\ prefix)" Margin="0,2,0,2"/>
                    <TextBox  Grid.Row="3" Text="{Binding BridgePipeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,2,0,2">
                        <TextBlock Text="Bridge log file path"/>
                        <TextBlock Text="{Binding LogPathStatus}"
                                   Foreground="{DynamicResource WarningForeground}"
                                   Margin="8,0,0,0" FontStyle="Italic"/>
                    </StackPanel>
                    <Grid Grid.Row="5" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Command="{Binding BrowseLogPathCommand}"
                                Margin="6,0,0,0"
                                ToolTip="Open a file picker to choose where the bridge log lives. The file may not exist yet — the bridge creates it on first probe."/>
                    </Grid>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Profile id: " Margin="0,0,6,0"/>
                        <TextBox Width="220" Text="{Binding ProfileId, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Auto-connect on startup" IsChecked="{Binding AutoConnectOnStartup}" Margin="16,0,0,0"/>
                        <CheckBox Content="Show advanced / dark helpers" IsChecked="{Binding ShowAdvancedHelpers}" Margin="16,0,0,0"/>
                        <TextBlock Text="    Theme:" Margin="16,0,6,0"/>
                        <ComboBox ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding Theme}"
                                  Width="120"
                                  ToolTip="system = follow Windows AppsUseLightTheme; dark / light = explicit. Auto-saves on change.">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource TextForeground}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Save" Command="{Binding SaveCommand}" MinWidth="100"/>
                        <Button Content="Reload from disk" Command="{Binding ReloadCommand}" MinWidth="140"/>
                        <!--
                            2026-04-27 (iter 18): operator escape hatch.
                            Confirmation-gated so an accidental click can't
                            wipe a customised configuration.
                        -->
                        <Button Content="Reset to defaults"
                                Command="{Binding ResetToDefaultsCommand}"
                                MinWidth="140" Margin="6,0,0,0"
                                ToolTip="Overwrite every Settings field with factory defaults and save. Gated by a Yes/No confirmation."/>
                        <!--
                            2026-04-27: launch the v2_settings.json + log
                            file in the OS default text editor. Power-users
                            edit fields the GUI doesn't surface (e.g.
                            plugin overrides) and tail the log when the
                            bridge misbehaves.
                        -->
                        <Button Content="Open settings file"
                                Command="{Binding OpenSettingsFileCommand}"
                                Margin="12,0,0,0"
                                ToolTip="Open the settings file in the OS default text editor."/>
                        <Button Content="Open log file"
                                Command="{Binding OpenLogFileCommand}"
                                Margin="6,0,0,0"
                                ToolTip="Open the bridge log in the OS default text editor."/>
                        <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" Foreground="{DynamicResource AccentForeground}"/>
                    </StackPanel>

                    <GroupBox Grid.Row="8" Header="Info">
                        <StackPanel>
                            <TextBlock Text="{Binding SettingsFilePath, StringFormat='Settings file: {0}'}" Foreground="{DynamicResource MutedForeground}" Margin="0,2"/>
                            <TextBlock Text="The bridge expects the injected powrprof.dll to write its log next to the game binary. If the log path is wrong, the diagnostics tab will show '(log directory missing)'." Foreground="{DynamicResource MutedForeground}" TextWrapping="Wrap" Margin="0,6,0,2"/>
                        </StackPanel>
                    </GroupBox>

                    <!--
                        2026-05-07 (iter 303): mod-picker GroupBox surfaces the
                        iter-301 SettingsTabViewModel.Mods collection +
                        ActiveMod + ModPickerStatus + RefreshModsCommand +
                        OpenModsFolderCommand. Cross-references iter-299
                        SWFOC_GetCurrentMod (active mod identification) +
                        iter-300 SWFOC_ListMods (full mod enumeration).
                        Closes 4 of 6 missing enumeration wires from iter-294
                        Audit B at the operator-clickable surface.
                    -->
                    <GroupBox Grid.Row="9" Header="Available Mods" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Status + currently-loaded badge -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Currently loaded: " VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ActiveMod}"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AccentForeground}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" — "
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"
                                           Margin="6,0"/>
                                <TextBlock Text="{Binding ModPickerStatus}"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <!-- Action row: Refresh + Open Mods folder -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4">
                                <Button Content="Refresh mods"
                                        Command="{Binding RefreshModsCommand}"
                                        ToolTip="Query SWFOC_ListMods + SWFOC_GetCurrentMod and rebuild the grid below."/>
                                <Button Content="Open Mods folder"
                                        Command="{Binding OpenModsFolderCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Launch File Explorer at the game's Mods/ directory. Drop sidecar mods here (e.g. stub-XML repair output)."/>
                            </StackPanel>
                            <!-- Mod list: Name / Path / IsCurrentlyLoaded -->
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding Mods}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      AlternatingRowBackground="{DynamicResource SurfaceAltBackground}"
                                      Margin="0,4,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Loaded" Binding="{Binding IsCurrentlyLoaded}" Width="60"/>
                                    <DataGridTextColumn Header="Mod name" Binding="{Binding Name}" Width="200"/>
                                    <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>

                    <!--
                        2026-05-07 (iter 310, Thread D arc post-finale): operator
                        UI for the iter-309 IconsRoot setting. Mirrors the iter-303
                        mod-picker GroupBox shape (input row + status row).
                        Operator runs the Python CLI extract pipeline once per
                        game install (meg_parser.py + thumbnail_cache.py per DDS),
                        then points this field at the extracted-textures root.
                        Editor restart still required for the iter-309 resolver
                        to pick up changes — surfaced in the badge text.
                    -->
                    <GroupBox Grid.Row="10" Header="Unit icons (Spawning tab)" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Extracted DDS root: "
                                       VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="0" Grid.Column="1"
                                       Text="{Binding IconsRoot, UpdateSourceTrigger=PropertyChanged}"
                                       VerticalContentAlignment="Center"
                                       ToolTip="Operator-supplied root dir holding extracted SWFOC DDS textures. Run python tools/asset_extractor/meg_parser.py + thumbnail_cache.py to populate it. Empty = no icons (graceful)."/>
                            <Button    Grid.Row="0" Grid.Column="2"
                                       Content="Browse..."
                                       Command="{Binding BrowseIconsRootCommand}"
                                       Margin="6,0,0,0"
                                       Padding="10,2"
                                       ToolTip="Pick the directory containing extracted SWFOC DDS textures (folder picker)."/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                       Text="{Binding IconsRootStatus}"
                                       Foreground="{DynamicResource MutedForeground}"
                                       FontSize="11"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 7: Tactical Units (Phase 1 thread A) -->
            <TabItem Header="Tactical Units" ToolTip="{Binding TooltipTacticalUnits}">
                <Grid DataContext="{Binding TacticalUnits}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Filters">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Faction slot: " VerticalAlignment="Center"/>
                            <TextBox  Grid.Column="1" Text="{Binding FactionSlotFilterText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Empty = all slots; integer = filter to that owner_slot"/>
                            <TextBlock Grid.Column="2" Text="    Search obj_addr (hex): " VerticalAlignment="Center"/>
                            <TextBox  Grid.Column="3" Text="{Binding TextFilter, UpdateSourceTrigger=PropertyChanged}"/>
                            <CheckBox Grid.Column="4" Content="    Selected only" Margin="12,0,0,0" IsChecked="{Binding SelectedOnlyFilter}"/>
                            <Button   Grid.Column="6" Content="Refresh" Command="{Binding RefreshCommand}"/>
                        </Grid>
                    </GroupBox>

                    <!-- 2026-04-27: export the filtered rows as CSV to the
                         clipboard. Header + one row per filtered unit.
                         Pure local op — no bridge work. -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,4,0,4"
                                VerticalAlignment="Bottom">
                        <Button Content="Export CSV"
                                Command="{Binding ExportCsvCommand}"
                                ToolTip="Copy the currently-filtered rows as CSV to the clipboard. Paste into Excel or Google Sheets for offline analysis."/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{Binding TotalRowCount, StringFormat='Total: {0}'}" Foreground="{DynamicResource AccentForeground}"/>
                        <TextBlock Text="    " />
                        <TextBlock Text="{Binding FilteredRowCount, StringFormat='Filtered: {0}'}" Foreground="{DynamicResource AccentForeground}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding FilteredRows}"
                              SelectedItem="{Binding SelectedRow}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              Background="{DynamicResource ListBackground}"
                              Foreground="{DynamicResource ListForeground}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrushBase}"
                              RowBackground="{DynamicResource ListBackground}"
                              AlternatingRowBackground="{DynamicResource AltRowBackground}"
                              FontFamily="Consolas, Lucida Console, monospace"
                              FontSize="11">
                        <!--
                            2026-04-27: right-click context menu so the
                            operator gets one-click access to common
                            row-level operations (copy addr in hex/decimal,
                            full CSV row). Saves the cell-by-cell Ctrl+C
                            workflow.
                        -->
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy obj_addr (hex)"
                                          Command="{Binding CopySelectedAddrHexCommand}"/>
                                <MenuItem Header="Copy obj_addr (decimal)"
                                          Command="{Binding CopySelectedAddrDecimalCommand}"/>
                                <Separator/>
                                <MenuItem Header="Copy row as CSV"
                                          Command="{Binding CopySelectedRowCsvCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Obj addr (hex)" Binding="{Binding ObjAddrHex}" Width="160"/>
                            <DataGridTextColumn Header="Owner slot"    Binding="{Binding OwnerSlot}"  Width="90"/>
                            <DataGridTextColumn Header="Hull"          Binding="{Binding Hull}"       Width="80"/>
                            <DataGridTextColumn Header="Invuln"        Binding="{Binding InvulnFlag}" Width="60"/>
                            <DataGridTextColumn Header="PreventDeath"  Binding="{Binding PreventDeath}" Width="100"/>
                            <DataGridCheckBoxColumn Header="Local"     Binding="{Binding IsLocal}"    Width="60"/>
                            <DataGridCheckBoxColumn Header="Selected"  Binding="{Binding IsSelected}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="3" Background="{DynamicResource TabBackground}" Padding="6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 8: Economy (Phase 1 thread A) -->
            <TabItem Header="Economy" ToolTip="{Binding TooltipEconomy}">
                <ScrollViewer DataContext="{Binding Economy}" Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Scope">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Slot: "/>
                                <TextBox Width="80" Text="{Binding Slot, UpdateSourceTrigger=PropertyChanged}" ToolTip="-1 = local player; 0..N = specific slot"/>
                                <TextBlock Text="    (use -1 for local player)" Foreground="{DynamicResource MutedForeground}" Margin="12,0,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Credits + Tech">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Credits amount: "/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding CreditsAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button    Grid.Row="0" Grid.Column="2" Content="Set credits" Command="{Binding SetCreditsCommand}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tech level (1..5): "/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding TechLevel, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button    Grid.Row="1" Grid.Column="2" Content="Set tech" Command="{Binding SetTechCommand}"/>

                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="Drain enemy" Command="{Binding DrainEnemyCommand}"/>
                                    <Button Content="Uncap credits" Command="{Binding UncapCreditsCommand}"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Multipliers">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Income mult: "/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding IncomeMultiplier, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button    Grid.Row="0" Grid.Column="2" Content="Apply" Command="{Binding SetIncomeMultCommand}"
                                           ToolTip="Disabled: SWFOC_SetIncomeMultiplier is PHASE 2 PENDING. Use GLOBAL credit multiplier below for the live-backed economy scalar."/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Build speed mult: "/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding BuildSpeedMultiplier, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button    Grid.Row="1" Grid.Column="2" Content="Apply" Command="{Binding SetBuildSpeedCommand}"
                                           ToolTip="Disabled: SWFOC_SetBuildSpeed is PHASE 2 PENDING until a live build-speed hook exists."/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Build cost mult: "/>
                                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding BuildCostMultiplier, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button    Grid.Row="2" Grid.Column="2" Content="Apply" Command="{Binding SetBuildCostCommand}"
                                           ToolTip="Disabled: SWFOC_SetBuildCost is PHASE 2 PENDING until a live build-cost hook exists."/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Toggles">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="FreezeCredits target: "/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding FreezeCreditsTarget, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button    Grid.Row="0" Grid.Column="2" Content="Toggle freeze" Command="{Binding ToggleFreezeCommand}"
                                           ToolTip="Disabled: per-slot SWFOC_FreezeCredits is PHASE 2 PENDING. Use the GLOBAL economy freeze controls below."/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding IsFreezeCreditsEnabled}" Foreground="{DynamicResource AccentForeground}"/>

                                <Button    Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Toggle InstantBuild" Command="{Binding ToggleInstantBuildCommand}"
                                           ToolTip="Disabled: SWFOC_InstantBuild is PHASE 2 PENDING until a live build-queue hook exists."/>
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding IsInstantBuildEnabled}" Foreground="{DynamicResource AccentForeground}"/>

                                <Button    Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Toggle FreeBuild" Command="{Binding ToggleFreeBuildCommand}"
                                           ToolTip="Disabled: SWFOC_FreeBuild is PHASE 2 PENDING until a live cost hook exists."/>
                                <TextBlock Grid.Row="2" Grid.Column="3" Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding IsFreeBuildEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                            </Grid>
                        </GroupBox>

                        <!--
                            2026-05-06 (iter 233): GLOBAL economy controls — LIVE via iter-231
                            AddCredits @ 0x27F370 MinHook detour. Pattern parallels iter-227
                            Combat tab "Apply (GLOBAL)" + Read (GLOBAL). Distinct surface from
                            the per-slot freeze/income mult above (those stay PHASE 2 PENDING).
                            Closes A1.x FreezeCredits arc after iter-230 RE design + iter-231/232
                            bridge+sim. See knowledge-base/iter230_freeze_credits_re_kickoff.md.
                        -->
                        <GroupBox Header="GLOBAL economy controls (LIVE)" Margin="0,8,0,0">
                            <Grid Margin="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Freeze on/off pair (hardcoded-bool, iter-204 lineage 8 iters deep) -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Credit freeze: " VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                                    <Button Content="Freeze on" Command="{Binding SetCreditsFreezeOnCommand}"
                                            ToolTip="SWFOC_SetCreditsFreezeGlobal(1). Short-circuits AddCredits @ 0x27F370 entirely (no write to PlayerClass+0x70, no events, no tracking). Blocks AI subsidies equally. Cap at +0x74 still applies on unfreeze."/>
                                    <Button Content="Freeze off" Command="{Binding SetCreditsFreezeOffCommand}" Margin="6,0,0,0"
                                            ToolTip="SWFOC_SetCreditsFreezeGlobal(0). Restores normal AddCredits flow."/>
                                    <TextBlock Text="{Binding SetCreditsFreezeGlobal.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               ToolTip="{Binding SetCreditsFreezeGlobal.Tooltip}"/>
                                </StackPanel>

                                <!-- Row 1: Multiplier text input + Apply (GLOBAL) + Read (GLOBAL) -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Credit mult: " VerticalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"
                                         Text="{Binding GlobalCreditsMultiplier, UpdateSourceTrigger=PropertyChanged}"/>
                                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="6,6,0,0">
                                    <StackPanel>
                                        <Button Content="Apply (GLOBAL)" Command="{Binding SetCreditsMultiplierGlobalCommand}"
                                                ToolTip="SWFOC_SetCreditsMultiplierGlobal(mult). Scales AddCredits delta arg. mult=2 → 2x income/spend; mult=0.5 → halved both; mult=0 → soft freeze. Clamped [0.0, 100.0]. Bool freeze precedence wins if active."/>
                                        <TextBlock Text="{Binding SetCreditsMultiplierGlobal.Badge}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForeground}"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                                   ToolTip="{Binding SetCreditsMultiplierGlobal.Tooltip}"/>
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <Button Content="Read (GLOBAL)" Command="{Binding GetCreditsMultiplierGlobalCommand}"
                                                ToolTip="Read-back the current g_creditsMult_global value the bridge has stored."/>
                                        <TextBlock Text="{Binding GetCreditsMultiplierGlobal.Badge}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForeground}"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                                   ToolTip="{Binding GetCreditsMultiplierGlobal.Tooltip}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <Border Background="{DynamicResource TabBackground}" Padding="6" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- =================================================== TAB 9: Inspector (Unit D) -->
            <TabItem Header="Inspector" ToolTip="{Binding TooltipInspector}">
                <Grid DataContext="{Binding Inspector}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- 2026-05-05 (iter 191): new row for read-side native UX GroupBox. -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Unit obj_addr (decimal or hex without 0x): "/>
                        <TextBox Width="220" Text="{Binding ObjAddrInput, UpdateSourceTrigger=PropertyChanged}" ToolTip="Paste from Tactical Units tab"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="10,0,0,0"/>
                        <Button Content="Clear" Command="{Binding ClearCommand}"/>
                        <!--
                            2026-04-27: copy-snapshot. Serialises current
                            Inspector state (addr, hull, owner, invuln,
                            preventDeath, isLocal, isSelected) as a JSON
                            blob to the clipboard. Bug-report ergonomics.
                        -->
                        <Button Content="Copy snapshot"
                                Command="{Binding CopySnapshotCommand}"
                                Margin="8,0,0,0"
                                ToolTip="Copy the current snapshot as a JSON blob to the clipboard for bug reports."/>
                        <!-- iter 90: focused alternative — copy just the addr hex for paste-into-other-tabs. -->
                        <Button Content="Copy addr"
                                Command="{Binding CopyObjAddrCommand}"
                                Margin="6,0,0,0"
                                ToolTip="Copy just the obj_addr as a hex string (0x...) to the clipboard. Useful for pasting into other tabs (Player State, Combat scalars, Speed) without grabbing the full snapshot."/>
                        <!--
                            2026-04-27: live-observation toggle. PeriodicTimer
                            fires Refresh every 2 sec while checked; stops
                            cleanly on uncheck / tab navigate / app close.
                        -->
                        <CheckBox Content="Auto-refresh (2s)"
                                  IsChecked="{Binding IsAutoRefreshEnabled}"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  ToolTip="Refresh the snapshot every 2 seconds so the Inspector tracks live hull / shield. Skips when no obj_addr is set."/>
                    </StackPanel>
                    <!--
                        2026-05-05 (iter 191): native UX surfacing for iter-168/169
                        unit-receiver read-side wires. Operator types a unit Lua
                        expression once (default Find_First_Object("Empire_AT_AT")),
                        then clicks any of the 4 buttons to query engine state.
                        Result lands in the LastStatus border at the bottom.
                        These are LIVE wires routed through the iter-167 unit-getter
                        helper — separate from the obj_addr-based snapshot above.
                    -->
                    <!-- 2026-05-07 (iter 379): UX polish — header was stale at "(iter 191)";
                         section grew through 4 sub-batches (iter-191 + iter-197 + iter-198 + iter-214)
                         spanning iter 168/169/171/172/173/174 read-side wires. ~18 buttons total. -->
                    <GroupBox Grid.Row="1" Header="Selected Unit Lua Read-side (~18 read-side wires)" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Unit Lua expression: " VerticalAlignment="Center"/>
                                <TextBox Width="400"
                                         Text="{Binding UnitLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Any Lua expression that resolves to a unit obj receiver. Examples: Find_First_Object(&quot;Empire_AT_AT&quot;), Find_Hero(&quot;Luke_Skywalker&quot;), GameObjectWrapper.Get(0)."
                                         FontFamily="Consolas, Lucida Console, monospace"/>
                            </StackPanel>
                            <WrapPanel>
                                <Button Content="Read unit type"
                                        Command="{Binding ReadUnitTypeLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="SWFOC_GetTypeLua → composes (unit):Get_Type() and returns the GameObjectType handle. Iter-169 LIVE wire."/>
                                <TextBlock Text="{Binding ReadUnitTypeLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ReadUnitTypeLuaAction.Tooltip}"/>
                                <Button Content="Read unit owner"
                                        Command="{Binding ReadUnitOwnerLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="SWFOC_GetOwnerLua → composes (unit):Get_Owner() and returns the PlayerWrapper handle. Iter-168 LIVE wire."/>
                                <TextBlock Text="{Binding ReadUnitOwnerLuaAction.Badge}"
