                                    <Button Content="Refresh hardpoints"
                                            Command="{Binding RefreshHardpointsCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="Calls SWFOC_GetHardpoints(addr) + parses count=N child=0x... hp=... format. Bounded to 32 children."/>
                                    <TextBlock Text="{Binding RefreshHardpoints.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding RefreshHardpoints.Tooltip}"/>
                                </WrapPanel>
                                <ListBox ItemsSource="{Binding Hardpoints}" MinHeight="80" MaxHeight="240"
                                         FontFamily="Consolas, Lucida Console, monospace" FontSize="11">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <!-- 2026-05-07 (iter 343): Approach A optimistic icon-resolution chain.
                                                 Image renders if SWFOC_GetTypeLua → ResolveWeaponIcon resolved an
                                                 icon; null IconPath collapses the Image so text-only row stays
                                                 visible. Operator gets graceful fallback. -->
                                            <StackPanel Orientation="Horizontal">
