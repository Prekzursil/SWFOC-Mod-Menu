                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </GroupBox>
                        <Border Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
