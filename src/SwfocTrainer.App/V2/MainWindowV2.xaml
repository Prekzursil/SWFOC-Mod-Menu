                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- =================================================== TAB 12: Spawning (Unit D) -->
            <TabItem Header="Spawning" ToolTip="{Binding TooltipSpawning}">
                <!-- iter 58: tab-level Phase-2-pending banner above the type browser.
                     The Spawn button is the most operator-confusing surface in the
                     editor (1/1 OK status on a non-engine call). -->
                <Grid DataContext="{Binding Spawning}" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Grid.ColumnSpan="2"
                            Background="{DynamicResource WarningBackground}"
                            BorderBrush="{DynamicResource WarningBorderBrush}"
                            BorderThickness="1"
                            Padding="8,6" Margin="0,0,0,8"
                            Visibility="{Binding HasPhase2PendingAction, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Phase2PendingWarning}"
                                   Foreground="{DynamicResource WarningForeground}"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Text="Type browser (search):"/>
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Substring match, case-insensitive — combine with faction/domain filters below."/>
                        <!--
                            2026-04-27: live-filter the on-disk catalog
                            against the running game. SWFOC_BatchTypeExists
                            (new bridge probe) asks the engine's
                            GameObjectTypeManager which catalog types are
                            actually loaded in the current session, so a
                            vanilla session never sees mod A's units and
                            mod A never sees mod B's. Round-trips up to 512
                            names per pipe call (the bridge enforces this);
                            the editor batches by 256 for safety headroom.
                        -->
                        <Button Content="Refresh from live game"
                                Command="{Binding RefreshFromLiveGameCommand}"
                                Margin="0,4,0,0" HorizontalAlignment="Stretch"
                                ToolTip="Filter the catalog against the running game's GameObjectTypeManager (vanilla / mod / submod isolation)."/>
                        <TextBlock Text="{Binding RefreshFromLiveGame.Badge}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedForeground}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding RefreshFromLiveGame.Tooltip}"/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource MutedForeground}"
                                   Text="(seed list comes from CatalogSources; click Refresh to keep only types the live game confirms)"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <!--
                            2026-04-27: faceted filters. Faction options are
                            auto-derived from the available-types list at
                            startup, so vanilla and every mod (AOTR, ROE,
                            ROTR, Thrawn's Revenge) populate themselves
                            without code changes. Domain is a heuristic
                            classifier inside SpawningTabState.ClassifyDomain.
                        -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Faction:" Margin="0,0,4,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Domain:" Margin="4,0,0,2"/>
                            <ComboBox  Grid.Row="1" Grid.Column="0" Margin="0,0,4,0"
                                       ItemsSource="{Binding AvailableFactions}"
                                       SelectedItem="{Binding SelectedFactionFilter}"
                                       ToolTip="Narrow the list to a single faction prefix (auto-detected from the type names — works for vanilla and every mod)."/>
                            <ComboBox  Grid.Row="1" Grid.Column="1" Margin="4,0,0,0"
                                       ItemsSource="{Binding AvailableDomains}"
                                       SelectedItem="{Binding SelectedDomainFilter}"
                                       ToolTip="Filter by Space / Ground / Unknown (heuristic — checks for 'FRIGATE', 'INFANTRY', 'WALKER' etc. in the type name)."/>
                        </Grid>
                    </StackPanel>
                    <!-- iter 308 (Thread D arc FINALE 2026-05-07): bind to FilteredTypeRows
                         instead of raw FilteredTypes so each row can render an in-game icon
                         (when iter-307 ThumbnailCache + iter-308 UnitIconResolver have a hit)
                         alongside the type name. SelectedTypeId still binds via SelectedValue
                         so existing spawn-flow + filter logic keep working unchanged. Null
                         IconPath silently hides the Image control — no broken-image
                         placeholder, no operator confusion when icons aren't extracted. -->
                    <ListBox Grid.Row="2" Grid.Column="0" Margin="0,0,8,8"
                             ItemsSource="{Binding FilteredTypeRows}"
                             SelectedValue="{Binding SelectedTypeId}"
                             SelectedValuePath="TypeId">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding IconPath}"
                                           Width="32" Height="32"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"
                                           ToolTip="{Binding TypeId}"/>
                                    <TextBlock Text="{Binding TypeId}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" Grid.RowSpan="2" Grid.Column="1">
                        <GroupBox Header="Selected type">
                            <TextBlock Text="{Binding SelectedTypeId}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="13"/>
                        </GroupBox>
                        <GroupBox Header="Spawn target">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Slot: "/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding FactionSlot, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="    Count: " Margin="12,0,0,0"/>
                                <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="X: "/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding PosX, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="    Y: " Margin="12,0,0,0"/>
                                <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding PosY, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Z: "/>
