                        -->
                        <!-- 2026-05-07 (iter 379): UX polish — header was stale at "(iter 177 + 186)";
                             section grew through iter-206 (Find_All_Objects_Of_Type — iter-179 wire).
                             5 LIVE wires total spanning iter 177/179/186 (full first/all/nearest trio). -->
                        <GroupBox Header="Discovery helpers (5 LIVE wires)" Margin="0,8,0,0">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Type / object name (Lua): " VerticalAlignment="Center"/>
                                    <TextBox Width="200" Text="{Binding FindTypeNameLuaExpr, UpdateSourceTrigger=PropertyChanged}"
