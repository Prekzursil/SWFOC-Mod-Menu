                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="{DynamicResource MutedForeground}"
                                           Margin="0,0,0,4"
                                           Text="Type a unit Lua expression (e.g. Find_First_Object(&quot;Empire_AT_AT&quot;)) and an optional float arg, then click any of the 4 buttons. Heal is no-arg; the other 3 take a multiplier or damage amount. The GLOBAL damage multiplier still applies — TakeDamage routes through Take_Damage_Outer."/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Unit:" Width="50" VerticalAlignment="Center"/>
                                    <TextBox Width="350"
                                             Text="{Binding CombatUnitLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas, Lucida Console, monospace"
                                             ToolTip="Lua expression resolving to a unit obj receiver."/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Arg:" Width="50" VerticalAlignment="Center"/>
                                    <TextBox Width="120"
                                             Text="{Binding CombatUnitArg, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas, Lucida Console, monospace"
