                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ChangeOwner.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                            <!--
                                2026-04-27 (iter 33) — Overlay Feature 3 surfaced as
                                two extra buttons. Same Planet ID + New owner inputs;
                                the buttons differ only in what happens to the
                                garrison.
                            -->
