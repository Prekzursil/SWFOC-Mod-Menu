                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Presets:" Margin="0,0,8,0"/>
                                    <Button Content="Pause"
                                            Command="{Binding ApplyPauseCommand}"
                                            ToolTip="Disabled: SWFOC_SetGameSpeed is PHASE 2 PENDING. Use per-faction or per-unit speed controls."/>
                                    <Button Content="0.5x"
                                            Command="{Binding ApplyHalfCommand}"
                                            ToolTip="Disabled: SWFOC_SetGameSpeed is PHASE 2 PENDING. Use per-faction or per-unit speed controls."/>
                                    <Button Content="1.0x"
                                            Command="{Binding ApplyRealtimeCommand}"
                                            ToolTip="Disabled: SWFOC_SetGameSpeed is PHASE 2 PENDING. Use per-faction or per-unit speed controls."/>
                                    <Button Content="2.0x"
                                            Command="{Binding Apply2xCommand}"
                                            ToolTip="Disabled: SWFOC_SetGameSpeed is PHASE 2 PENDING. Use per-faction or per-unit speed controls."/>
                                    <Button Content="4.0x"
                                            Command="{Binding Apply4xCommand}"
                                            ToolTip="Disabled: SWFOC_SetGameSpeed is PHASE 2 PENDING. Use per-faction or per-unit speed controls."/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Per-faction move speed">
                            <StackPanel>
                                <Border Background="{DynamicResource SuccessBackground}"
                                        BorderBrush="{DynamicResource SuccessBorderBrush}"
                                        BorderThickness="1" CornerRadius="2"
                                        Padding="8,4" Margin="0,0,0,6">
                                    <TextBlock Text="✓  LIVE  —  Apply enumerates units by slot and calls SetSpeedOverride per unit"
                                               Foreground="{DynamicResource SuccessForeground}"
                                               FontWeight="Bold" FontSize="11"/>
                                </Border>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Slot: "/>
                                    <TextBox Width="60" Text="{Binding FactionSlot, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="    Multiplier: " Margin="12,0,0,0"/>
                                    <TextBox Width="80" Text="{Binding FactionMoveSpeedMultiplier, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Margin="10,0,0,0">
                                        <Button Content="Apply" Command="{Binding SetFactionSpeedCommand}"
                                                ToolTip="SWFOC_SetPerFactionSpeedMultiplier → live-backed unit enumeration with SetSpeedOverride."/>
                                        <TextBlock Text="{Binding SetFactionSpeed.Badge}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForeground}"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetFactionSpeed.Tooltip}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- iter 77: per-faction speed presets — one-click multipliers for the currently selected faction slot. -->
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Presets:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Content="Snail (0.25×)" Command="{Binding ApplyFactionSnailCommand}"
                                            ToolTip="One-click: Slot's faction move-speed multiplier = 0.25× (debugging movement / extreme slow)" Margin="0,0,4,0"/>
                                    <Button Content="Slow (0.5×)" Command="{Binding ApplyFactionSlowCommand}"
                                            ToolTip="One-click: Slot's faction move-speed multiplier = 0.5× (cinematic feel)" Margin="0,0,4,0"/>
                                    <Button Content="Normal (1.0×)" Command="{Binding ApplyFactionNormalCommand}"
                                            ToolTip="One-click: Slot's faction move-speed multiplier = 1.0× (canonical reset)" Margin="0,0,4,0"/>
                                    <Button Content="Fast (2.0×)" Command="{Binding ApplyFactionFastCommand}"
                                            ToolTip="One-click: Slot's faction move-speed multiplier = 2.0× (speedrun)"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Per-unit speed">
                            <StackPanel>
                                <Border Background="{DynamicResource SuccessBackground}"
                                        BorderBrush="{DynamicResource SuccessBorderBrush}"
                                        BorderThickness="1" CornerRadius="2"
                                        Padding="8,4" Margin="0,0,0,6">
                                    <TextBlock Text="✓  LIVE  —  Apply calls SetSpeedOverride engine helper, Revert calls ClearSpeedOverride"
                                               Foreground="{DynamicResource SuccessForeground}"
                                               FontWeight="Bold" FontSize="11"/>
                                </Border>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="obj_addr (decimal): "/>
                                    <TextBox Width="160" Text="{Binding SelectedObjAddr, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="    Speed: " Margin="12,0,0,0"/>
                                    <TextBox Width="80" Text="{Binding UnitSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Margin="10,0,0,0">
                                        <Button Content="Apply" Command="{Binding SetUnitSpeedCommand}"
                                                ToolTip="LIVE — calls SetSpeedOverride @ RVA 0x3A8C90 → writes locomotor +0x2A0 + sets active flag at +0x29C"/>
                                        <TextBlock Text="{Binding SetUnitSpeed.Badge}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForeground}"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetUnitSpeed.Tooltip}"/>
                                    </StackPanel>
                                    <StackPanel Margin="10,0,0,0">
                                        <Button Content="Revert" Command="{Binding ClearUnitSpeedOverrideCommand}"
                                                ToolTip="LIVE — calls ClearSpeedOverride @ RVA 0x38F8B0 → clears the active flag and reverts to engine's natural max speed"/>
                                        <TextBlock Text="{Binding ClearUnitSpeedOverride.Badge}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForeground}"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ClearUnitSpeedOverride.Tooltip}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- iter 77: per-unit speed presets — one-click speeds for the currently selected obj_addr. -->
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Presets:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Content="Slow (2.5)" Command="{Binding ApplyUnitSlowCommand}"
                                            ToolTip="One-click: selected unit's speed = 2.5 (slowed infantry feel)" Margin="0,0,4,0"/>
                                    <Button Content="Normal (5.0)" Command="{Binding ApplyUnitNormalCommand}"
                                            ToolTip="One-click: selected unit's speed = 5.0 (default infantry)" Margin="0,0,4,0"/>
                                    <Button Content="Fast (10.0)" Command="{Binding ApplyUnitFastCommand}"
                                            ToolTip="One-click: selected unit's speed = 10.0 (speeder-bike feel)" Margin="0,0,4,0"/>
                                    <Button Content="Sprint (20.0)" Command="{Binding ApplyUnitSprintCommand}"
                                            ToolTip="One-click: selected unit's speed = 20.0 (vehicle stress test)"/>
