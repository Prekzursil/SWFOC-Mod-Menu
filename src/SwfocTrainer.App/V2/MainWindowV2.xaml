                            <Button Content="Save path..."
                                    Command="{Binding SavePathCommand}"
                                    Margin="12,0,0,0"
                                    ToolTip="Serialise the current waypoint list to a JSON file."/>
                            <Button Content="Load path..."
                                    Command="{Binding LoadPathCommand}"
                                    Margin="6,0,0,0"
                                    ToolTip="Replace the current waypoint list with one loaded from a JSON file."/>
                        </StackPanel>
                        <GroupBox Header="Time scale (slow-mo / freeze / fast-forward)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Scale: "/>
                                <TextBox Width="80" Text="{Binding TimeScale, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Apply" Command="{Binding SetTimeScaleCommand}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Hide UI">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Toggle hide UI" Command="{Binding ToggleHideUiCommand}"/>
                                <TextBlock Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Text="{Binding IsHideUiEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Playback">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Start" Command="{Binding StartPlaybackCommand}"/>
                                <Button Content="Step" Command="{Binding StepPlaybackCommand}"/>
                                <Button Content="Stop" Command="{Binding StopPlaybackCommand}"/>
                                <TextBlock Text="    running: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Text="{Binding IsPlaybackRunning}" Foreground="{DynamicResource AccentForeground}"/>
                                <TextBlock Text="    waypoint: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Text="{Binding CurrentWaypointIndex}" Foreground="{DynamicResource AccentForeground}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                    <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <!-- =================================================== TAB 21: Cross-Faction Recruitment (Unit D) -->
            <TabItem Header="Cross-Faction" ToolTip="{Binding TooltipCrossFaction}">
                <ScrollViewer DataContext="{Binding CrossFaction}" Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Source unit (must be local)">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="obj_addr (dec or hex w/o 0x): "/>
                                    <TextBox Width="200" Text="{Binding ObjAddrInput, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Source owner slot: "/>
                                    <TextBox Width="60" Text="{Binding SourceOwnerSlot, UpdateSourceTrigger=PropertyChanged}"/>
                                    <CheckBox Margin="12,0,0,0" Content="source is local" IsChecked="{Binding SourceIsLocal}"/>
                                </StackPanel>
                                <!--
                                    2026-04-27: workflow shortcut. Reads
                                    SWFOC_GetSelectedUnit and pre-fills
                                    addr + slot + is_local — eliminates
                                    the copy-from-Tactical-Units round trip.
                                -->
                                <Button Content="Auto-fill from in-game selection"
                                        Command="{Binding AutoFillFromSelectedCommand}"
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Left"
                                        ToolTip="Read SWFOC_GetSelectedUnit and populate the source obj_addr / slot / is_local fields. Requires a unit to be selected in-game."/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Recruit destination">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Target slot: "/>
                                <TextBox Width="60" Text="{Binding TargetSlot, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Recruit" Command="{Binding RecruitCommand}" Margin="10,0,0,0" Padding="20,3"/>
                            </StackPanel>
                        </GroupBox>
                        <!--
                            2026-04-27: live preview banner. RecruitPreview
                            re-evaluates on every input change and surfaces
                            no-op / invalid conditions BEFORE the operator
                            clicks Recruit (no point in a round-trip when
                            the State will reject it anyway). Warning amber
                            kicks in when source.OwnerSlot == target or
                            input is empty/invalid.
                        -->
                        <Border Background="{DynamicResource WarningBackground}"
                                BorderBrush="{DynamicResource WarningBorderBrush}"
                                BorderThickness="1" CornerRadius="2"
                                Padding="8,4" Margin="0,8,0,0"
                                Visibility="{Binding WarningVisibility}">
                            <TextBlock Text="{Binding RecruitPreview}"
                                       Foreground="{DynamicResource WarningForeground}"
                                       FontWeight="Bold" FontSize="11"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <Border Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0"
                                Visibility="{Binding InfoVisibility}">
                            <TextBlock Text="{Binding RecruitPreview}"
                                       Foreground="{DynamicResource AccentForeground}"
                                       FontFamily="Consolas, Lucida Console, monospace"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <Border Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- =================================================== TAB 22: Unit Stat Editor (Unit D) -->
            <TabItem Header="Unit Stat Editor" ToolTip="{Binding TooltipUnitStatEditor}">
                <Grid DataContext="{Binding UnitStatEditor}" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <GroupBox Grid.Row="0" Grid.Column="0" Header="Stage edit" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Field: "/>
                            <ComboBox Width="160" ItemsSource="{Binding EditFieldOptions}" SelectedItem="{Binding EditField}"/>
                            <TextBlock Text="    Value: " Margin="12,0,0,0"/>
                            <TextBox Width="120" Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Stage" Command="{Binding StageEditCommand}" Margin="10,0,0,0"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Row="1" Grid.Column="0" Header="Target obj_addrs (paste comma- or whitespace-separated; assumed local)" Margin="0,8,8,8">
                        <StackPanel>
                            <TextBox Height="80" AcceptsReturn="True"
                                     Text="{Binding TargetObjAddrsInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"/>
                            <TextBlock Text="{Binding SelectedUnitCount, StringFormat='Selected unit count: {0}'}"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource AccentForeground}"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Header="Staged edits">
                        <StackPanel>
                            <ListBox ItemsSource="{Binding Staged}" Height="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding FieldName, Mode=OneWay}"/>
                                            <Run Text=" = "/>
                                            <Run Text="{Binding Value, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Content="Clear staged" Command="{Binding ClearStagedCommand}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>
                    <Button Grid.Row="3" Grid.Column="0" Content="Apply all staged to all targets"
                            Command="{Binding ApplyAllCommand}"
                            HorizontalAlignment="Left" Padding="20,5" Margin="0,0,0,8"/>
                    <Border Grid.Row="4" Grid.ColumnSpan="2" Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 24: Asset Browser (iter 321) -->
            <!-- iter 321: cross-asset-class browser. Walks IconsRoot for all
                 i_*_*.dds prefixes (unit/hero/planet/faction) and surfaces
                 them in one DataGrid. Closes the iter-313 honest defer;
                 5th tab in the icon-resolver hot-swap chain. -->
            <TabItem Header="Asset Browser">
                <Grid DataContext="{Binding AssetBrowser}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                ToolTip="Walk IconsRoot for all i_button_*/i_portrait_*/i_planet_*/i_faction_* DDS files and populate the DataGrid below."/>
                        <TextBlock Text="{Binding LastStatus}"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedForeground}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Text="Cross-asset browser. Set IconsRoot in Settings tab, then click Refresh. Categories: unit (i_button_*) / hero (i_portrait_*) / planet (i_planet_*) / faction (i_faction_*)."
                               Foreground="{DynamicResource MutedForeground}"
                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Assets}" AutoGenerateColumns="False"
                              IsReadOnly="True" Background="{DynamicResource ChromeBackground}"
                              Foreground="{DynamicResource TextForeground}" GridLinesVisibility="None"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding IconPath}"
                                               Width="32" Height="32"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Name}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="240"/>
                            <DataGridTextColumn Header="DDS path" Binding="{Binding DdsPath}"  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- =================================================== Savegame Rescue (iter 466, 2026-05-07) -->
            <!-- Offline operator surface for the tools/savegame_rescue/ Python
                 toolkit. No SWFOC attach required. Backup / Diagnose / Diff /
                 Repair workflows. -->
            <TabItem Header="Savegame Rescue"
                     Visibility="{Binding SavegameTabsVisibility}">
                <Grid DataContext="{Binding SavegameRescue}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: status banner -->
                    <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Foreground="White" FontWeight="Bold"
                                       Text="Savegame Rescue (offline — does not require SWFOC attach)"/>
                            <TextBlock Foreground="#B3D4F8" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Wraps tools/savegame_rescue/ Python toolkit. Backs up your save folder before risky edits, diagnoses corruption, surgically repairs runaway AI TaskForce chunks, and detects anomalous growth. Always Backup-All first."/>
                            <TextBlock Margin="0,4,0,0" FontStyle="Italic"
                                       Foreground="{DynamicResource MutedForeground}">
                                <Run Text="Status: "/>
                                <Run Text="{Binding Status, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Row 1: paths -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Save dir: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="1" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Tools root: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="3" Text="{Binding ToolsRoot, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 ToolTip="Root of swfoc_memory repo. Override with env SWFOC_RESCUE_TOOLS or set explicitly."/>
                    </Grid>

                    <!-- Row 2: action buttons + chunk_id input -->
                    <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                        <Button Content="Refresh saves"
                                Command="{Binding RefreshSavesCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                ToolTip="List all .PetroglyphFoC*Save files in the Save dir."/>
                        <Button Content="Backup ALL (snapshot)"
                                Command="{Binding BackupAllCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                Background="#2D5F3E" Foreground="White"
                                ToolTip="Create timestamped backup of every save in Save Dir to ..\Save_Backups\YYYYMMDD-HHMMSS\ with SHA256 manifest. ALWAYS RUN FIRST."/>
                        <Button Content="Diagnose selected"
                                Command="{Binding DiagnoseSelectedCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                ToolTip="Parse the save selected in the list above, print structural summary + chunk_id histogram."/>
                        <Button Content="Compare (baseline vs selected)"
                                Command="{Binding CompareCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                ToolTip="Diff Baseline (good save) against Selected (suspect save). Use right-click context to set baseline."/>
                        <Button Content="Scan for runaway growth"
                                Command="{Binding ScanRunawayCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                ToolTip="Auto-detect anomalous chunk-id growth across all saves in chronological order. Catches new soft-lock patterns."/>
                        <Border Background="#3A1F1F" CornerRadius="3" Padding="6,2" Margin="20,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Strip chunk_id (hex): " VerticalAlignment="Center"
                                           Foreground="#FFB3B3"/>
                                <TextBox Width="80" VerticalAlignment="Center"
                                         Text="{Binding StripChunkIdHex, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="0x4B5 = AI TaskForce (AOTR runaway pattern). Other chunk_ids: see Diagnose output."/>
                                <Button Content="REPAIR (strip new chunks)"
                                        Command="{Binding RepairCommand}"
                                        Padding="10,3" Margin="8,0,0,0"
                                        Background="#7A2A2A" Foreground="White" FontWeight="Bold"
                                        ToolTip="Identity-diff Selected vs Baseline; remove chunks of given id present in Selected but absent in Baseline. Output written next to Selected with timestamp suffix."/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- Row 3: split between save list (left) and output (right) -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Save list -->
                        <Border Grid.Column="0" BorderBrush="{DynamicResource ChromeBorder}"
                                BorderThickness="1" CornerRadius="3" Margin="0,0,8,0">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Background="{DynamicResource ChromeBackground}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Saves (newest first)"
                                               FontWeight="Bold" Margin="8,4"/>
                                    <TextBlock Grid.Column="1" Margin="8,4"
                                               Foreground="{DynamicResource MutedForeground}"
                                               Text="(Click row = Selected; Ctrl+click = Baseline)"/>
                                </Grid>
                                <DataGrid ItemsSource="{Binding Saves}" AutoGenerateColumns="False"
                                          IsReadOnly="True" SelectionMode="Single"
                                          SelectedValuePath="FullPath"
                                          SelectedValue="{Binding SelectedSavePath, Mode=TwoWay}"
                                          GridLinesVisibility="None">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Modified"
                                                            Binding="{Binding Modified}" Width="120"/>
                                        <DataGridTextColumn Header="Size"
                                                            Binding="{Binding SizeMb}" Width="65"/>
                                        <DataGridTextColumn Header="Filename"
                                                            Binding="{Binding Name}" Width="*"/>
                                    </DataGrid.Columns>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource StringEqualsMultiConverter}">
                                                            <Binding Path="FullPath"/>
                                                            <Binding Path="DataContext.BaselineSavePath"
                                                                     RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Background" Value="#2D5F3E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Baseline path + output panel -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Baseline (good save): "
                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                           Foreground="{DynamicResource MutedForeground}"/>
                                <TextBox Grid.Column="1" Text="{Binding BaselineSavePath, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         ToolTip="Full path to a known-good save used as the comparison anchor for Compare and Repair."/>
                                <Button Grid.Column="2" Content="Clear output"
                                        Command="{Binding ClearOutputCommand}"
                                        Padding="6,3" Margin="8,0,0,0"/>
                            </Grid>
                            <Border Grid.Row="1" BorderBrush="{DynamicResource ChromeBorder}"
                                    BorderThickness="1" CornerRadius="3"
                                    Background="{DynamicResource ChromeBackground}">
                                <ListBox ItemsSource="{Binding Output}"
                                         FontFamily="Consolas, Cascadia Mono, monospace"
                                         FontSize="11"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingStackPanel.IsVirtualizing="True"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- =================================================== Save Monitor (iter 467, 2026-05-07) -->
            <TabItem Header="Save Monitor"
                     Visibility="{Binding SavegameTabsVisibility}">
                <Grid DataContext="{Binding SaveMonitor}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1F3A1F" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Foreground="White" FontWeight="Bold"
                                       Text="Save Monitor — early-warning system for save corruption"/>
                            <TextBlock Foreground="#B3F8C0" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Watches the Save folder; logs every save event with size delta. Surfaces a warning when a save grows by more than the threshold vs its prior version — the iter-466 soft-lock pattern is detectable as runaway file-size growth before the engine actually freezes."/>
                            <TextBlock Margin="0,4,0,0" FontStyle="Italic"
                                       Foreground="{DynamicResource MutedForeground}">
                                <Run Text="Status: "/>
                                <Run Text="{Binding Status, Mode=OneWay}"/>
                                <Run Text="   Warnings: "/>
                                <Run Text="{Binding WarningCount, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Save dir: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="1" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                        <Button Content="Start watching"
                                Command="{Binding StartCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                Background="#2D5F3E" Foreground="White"/>
                        <Button Content="Stop"
                                Command="{Binding StopCommand}"
                                Padding="10,5" Margin="0,0,8,0"/>
                        <Button Content="Clear log"
                                Command="{Binding ClearLogCommand}"
                                Padding="10,5" Margin="0,0,8,0"/>
                        <TextBlock Text="Warn threshold (MB): " VerticalAlignment="Center"
                                   Margin="20,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Width="60" VerticalAlignment="Center"
                                 ToolTip="Save grows by this many MB vs prior tick of the SAME save = warning fires.">
                            <TextBox.Text>
                                <Binding Path="GrowthWarnBytes" Mode="TwoWay" UpdateSourceTrigger="LostFocus"/>
                            </TextBox.Text>
                        </TextBox>
                    </WrapPanel>

                    <Border Grid.Row="3" BorderBrush="{DynamicResource ChromeBorder}"
                            BorderThickness="1" CornerRadius="3"
                            Background="{DynamicResource ChromeBackground}">
                        <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False"
                                  IsReadOnly="True" GridLinesVisibility="None"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"     Binding="{Binding Time}"     Width="80"/>
                                <DataGridTextColumn Header="Filename" Binding="{Binding Filename}" Width="*"/>
                                <DataGridTextColumn Header="Size"     Binding="{Binding SizeMb}"   Width="80"/>
                                <DataGridTextColumn Header="Δ vs prior" Binding="{Binding DeltaMb}" Width="100"/>
                                <DataGridTextColumn Header="Note"     Binding="{Binding Note}"     Width="2*"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                            <Setter Property="Background" Value="#7A2A2A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- =================================================== Save Auto-Tools (iter 468, 2026-05-07) -->
            <TabItem Header="Save Auto-Tools"
                     Visibility="{Binding SavegameTabsVisibility}">
                <Grid DataContext="{Binding SaveAutoTools}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#3F2F1F" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Foreground="White" FontWeight="Bold"
                                       Text="Save Auto-Tools — custom autosave + interval snapshot"/>
                            <TextBlock Foreground="#F5D8B3" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Auto-copies your newest save to a labeled archive folder either (a) every time the source file mutates (auto-copy), or (b) every N minutes (interval). Honest scope: this responds to game saves; it cannot trigger an in-game save without a SWFOC_RequestSave bridge wire (currently absent)."/>
                            <TextBlock Margin="0,4,0,0" FontStyle="Italic"
                                       Foreground="{DynamicResource MutedForeground}">
                                <Run Text="Status: "/>
                                <Run Text="{Binding Status, Mode=OneWay}"/>
                                <Run Text="   Snapshots taken: "/>
                                <Run Text="{Binding SnapshotsTaken, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Save dir: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="1" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Archive dir: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="3" Text="{Binding ArchiveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Pattern prefix: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="1" Text="{Binding PatternPrefix, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                 ToolTip="Files are written as &lt;prefix&gt;_NNNN_YYYYMMDDTHHMMSSZ.PetroglyphFoC64Save"/>
                        <TextBlock Grid.Column="2" Text="Interval (min): " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="3" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBox.Text>
                                <Binding Path="IntervalMinutes" Mode="TwoWay" UpdateSourceTrigger="LostFocus"/>
                            </TextBox.Text>
                        </TextBox>
                        <TextBlock Grid.Column="4" Text="Keep last: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="5" VerticalAlignment="Center"
                                 ToolTip="Older snapshots beyond this count are pruned automatically.">
                            <TextBox.Text>
                                <Binding Path="MaxKeep" Mode="TwoWay" UpdateSourceTrigger="LostFocus"/>
                            </TextBox.Text>
                        </TextBox>
                    </Grid>

                    <WrapPanel Grid.Row="3" Margin="0,0,0,8">
                        <Button Content="Enable auto-copy"
                                Command="{Binding EnableAutoCopyCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                Background="#2D5F3E" Foreground="White"
                                ToolTip="Watch SaveDir; copy newest save to archive on every mutation (debounced 3s)."/>
                        <Button Content="Disable auto-copy"
                                Command="{Binding DisableAutoCopyCommand}"
                                Padding="10,5" Margin="0,0,8,0"/>
                        <Button Content="Enable interval"
                                Command="{Binding EnableIntervalCommand}"
                                Padding="10,5" Margin="20,0,8,0"
                                Background="#2D5F3E" Foreground="White"
                                ToolTip="Every N minutes, copy the newest save to archive."/>
                        <Button Content="Disable interval"
                                Command="{Binding DisableIntervalCommand}"
                                Padding="10,5" Margin="0,0,8,0"/>
                        <Button Content="Snapshot now"
                                Command="{Binding SnapshotNowCommand}"
                                Padding="10,5" Margin="20,0,8,0"
                                ToolTip="Manual: copy newest save to archive immediately."/>
                        <Button Content="Open archive folder"
                                Command="{Binding OpenArchiveCommand}"
                                Padding="10,5" Margin="0,0,8,0"/>
                        <Button Content="Clear log"
                                Command="{Binding ClearLogCommand}"
                                Padding="10,5" Margin="0,0,8,0"/>
                    </WrapPanel>

                    <Border Grid.Row="4" BorderBrush="{DynamicResource ChromeBorder}"
                            BorderThickness="1" CornerRadius="3"
                            Background="{DynamicResource ChromeBackground}">
                        <ListBox ItemsSource="{Binding Log}"
                                 FontFamily="Consolas, Cascadia Mono, monospace"
                                 FontSize="11"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- =================================================== Galaxy Visualizer (iter 471, 2026-05-07) -->
            <!-- Animated save-state dashboard with per-save health cards,
                 corruption signals, and a mock galaxy mini-map. Real planet
                 rendering deferred until 0x3EA primary-state chunk extraction
                 lands (planet positions are inside that 83 MB container). -->
            <TabItem Header="Galaxy Visualizer"
                     Visibility="{Binding SavegameTabsVisibility}">
                <Grid DataContext="{Binding GalaxyVisualizer}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1F1A3A" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Foreground="White" FontWeight="Bold"
                                           Text="Galaxy Visualizer — animated save-state dashboard"/>
                                <TextBlock Foreground="#C0B8E8" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Each save is a card sized by file growth, colored by health (green/amber/red). Anomaly badge fires when growth vs prior save exceeds 5 MB — the canonical soft-lock signature. Planet roster + faction tokens are extracted live from the save bytes (0x3EA / 0x3E9 / 0x3EB chunks) — see the Inspect button. A visual galactic mini-map is a future enhancement."/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Padding="14,5" VerticalAlignment="Top"
                                    Background="#4A2A8A" Foreground="White"
                                    ToolTip="Walk SaveDir, compute per-save health metrics, refresh the dashboard."/>
                        </Grid>
                    </Border>

                    <!-- Row 1: aggregate metrics row -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1A2A1A" CornerRadius="4" Padding="10" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock Text="Total saves" Foreground="#90C090" FontSize="11"/>
                                <TextBlock Text="{Binding TotalSaves, Mode=OneWay}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#3A1A1A" CornerRadius="4" Padding="10" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="Anomalous" Foreground="#F08585" FontSize="11"/>
                                <TextBlock Text="{Binding AnomalousSaves, Mode=OneWay}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#1A2A3A" CornerRadius="4" Padding="10" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="Avg health" Foreground="#90B0F0" FontSize="11"/>
                                <TextBlock Text="{Binding AverageHealthLabel, Mode=OneWay}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="#2A1A3A" CornerRadius="4" Padding="10" Margin="4,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Status" Foreground="#C8B0F0" FontSize="11"/>
                                <TextBlock Text="{Binding Status, Mode=OneWay}"
                                           Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Row 2: SaveDir input -->
                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Save dir: " VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <TextBox Grid.Column="1" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Row 3: split between save cards (left) and galaxy mini-map (right) -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Save cards with animated fade-in + health bars -->
                        <Border Grid.Column="0" BorderBrush="{DynamicResource ChromeBorder}"
                                BorderThickness="1" CornerRadius="3" Margin="0,0,8,0"
                                Background="{DynamicResource ChromeBackground}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Cards}" Margin="6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="270" Margin="6"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="2"
                                                    CornerRadius="4"
                                                    Background="#181820"
                                                    Padding="10,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <EventTrigger RoutedEvent="Border.Loaded">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0" To="1"
                                                                                         Duration="0:0:0.5"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                                   Foreground="White" FontWeight="Bold" FontSize="11"
                                                                   TextWrapping="Wrap" ToolTip="{Binding Name}"/>
                                                        <Border Grid.Column="1"
                                                                Background="{Binding HealthBrush}"
                                                                CornerRadius="2" Padding="4,1" Margin="4,0,0,0">
                                                            <TextBlock Text="{Binding AnomalyBadge}"
                                                                       Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Modified}"
                                                               Foreground="#A0A0B0" FontSize="10" Margin="0,4,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0">
                                                            <Run Text="{Binding SizeMb, Mode=OneWay}" Foreground="#D8D8E8"/>
                                                            <Run Text="  Δ "/>
                                                            <Run Text="{Binding DeltaMb, Mode=OneWay}" Foreground="#F0C080"/>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="1" Text="{Binding GrowthLabel}"
                                                                   Foreground="#A0C0F0" FontSize="10"/>
                                                    </Grid>
                                                    <Grid Margin="0,6,0,0" Height="6">
                                                        <Border Background="#303038" CornerRadius="2"/>
                                                        <Border Width="{Binding HealthBarWidth}"
                                                                HorizontalAlignment="Left"
                                                                Background="{Binding HealthBrush}"
                                                                CornerRadius="2"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding HealthLabel}"
                                                               Foreground="#90A0B0" FontSize="9"
                                                               HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- Real save-state visualization: file-size growth curve (top)
                             + chunk-id distribution from Python parser (middle) +
                             extracted galactic state with real planet roster (bottom).
                             All from REAL save data — no mock state. -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Real file-size growth curve over time -->
                            <Border Grid.Row="0" BorderBrush="{DynamicResource ChromeBorder}"
                                    BorderThickness="1" CornerRadius="3"
                                    Background="#0A0A18" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#181828" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Save-size growth (chronological)"
                                                       Foreground="#B0B0D0" FontWeight="Bold" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Foreground="#90A0B0" FontSize="10">
                                                <Run Text="max "/>
                                                <Run Text="{Binding GrowthMaxMb, StringFormat={}{0:F0} MB, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <Canvas Grid.Row="1" Width="600" Height="220"
                                            Background="#08081A" ClipToBounds="True"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Path Stroke="#67C8E0" StrokeThickness="2"
                                              Data="{Binding GrowthCurvePath}"/>
                                        <ItemsControl ItemsSource="{Binding GrowthCurve}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="8" Height="8"
                                                             Stroke="White" StrokeThickness="1"
                                                             ToolTip="{Binding Tooltip}">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#67C8E0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAnomalous}" Value="True">
                                                                        <Setter Property="Fill" Value="#E04A4A"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                        </ItemsControl>
                                    </Canvas>
                                    <Border Grid.Row="2" Background="#181828" Padding="8,4">
                                        <TextBlock Foreground="#90A0B0" FontSize="10"
                                                   Text="Cyan dots = saves; red dots = anomalous growth (&gt;5 MB jump vs prior). Real file metadata."/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Real chunk-id distribution from Python parser -->
                            <Border Grid.Row="1" BorderBrush="{DynamicResource ChromeBorder}"
                                    BorderThickness="1" CornerRadius="3"
                                    Background="#0A0A18" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#181828" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Chunk-ID distribution of selected save"
                                                           Foreground="#B0B0D0" FontWeight="Bold" FontSize="11"/>
                                                <TextBlock Text="{Binding InspectStatus, Mode=OneWay}"
                                                           Foreground="#90A0B0" FontSize="10" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Inspect selected"
                                                    Command="{Binding InspectSelectedCommand}"
                                                    Padding="10,3" Background="#2D5F3E" Foreground="White"
                                                    ToolTip="Run the Python parser on the selected save (set SelectedSavePath via the cards) and show its chunk-id distribution from REAL save bytes."/>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ChunkSlices}" Margin="6">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,2" Padding="4,2" CornerRadius="2"
                                                            Background="#181828">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="220"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                       Foreground="#D0D0E0" FontFamily="Consolas" FontSize="11"/>
                                                            <Grid Grid.Column="1" Margin="6,2,8,2">
                                                                <Border Background="#28283A" Height="10" CornerRadius="2"/>
                                                                <Border Width="{Binding BarWidth}" Height="10"
                                                                        HorizontalAlignment="Left"
                                                                        Background="{Binding Fill}" CornerRadius="2"/>
                                                            </Grid>
                                                            <TextBlock Grid.Column="2" Text="{Binding CountLabel}"
                                                                       Foreground="#90A0B0" FontSize="10" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding SizeMb}"
                                                                       Foreground="#A0B0C0" FontSize="10" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding PercentLabel}"
                                                                       Foreground="#67C8E0" FontSize="10" FontWeight="Bold" Width="50" TextAlignment="Right"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <!-- Real galactic state: extracted planet roster
                                 from extract_galaxy_state.py string-mining of 0x3EA + 0x3E9
                                 + 0x3EB chunks. Real planet name hits + co-located faction
                                 tokens — no mock state. Auto-runs on Inspect Selected. -->
                            <Border Grid.Row="2" BorderBrush="{DynamicResource ChromeBorder}"
                                    BorderThickness="1" CornerRadius="3"
                                    Background="#0A0A18" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#181828" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Foreground="#C8B0F0" FontWeight="Bold" FontSize="11">
                                                    <Run Text="Extracted galactic state — "/>
                                                    <Run Text="{Binding PlanetCount, Mode=OneWay, StringFormat={}{0} planets}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding PlanetStatus, Mode=OneWay}"
                                                           Foreground="#90A0B0" FontSize="10" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#2A1A3A" CornerRadius="3" Padding="6,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FactionSummary, Mode=OneWay}"
                                                           Foreground="#D0C0F8" FontSize="10"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock Grid.Row="1" Foreground="#90A0B0" FontSize="10" Padding="8,2,8,4">
                                        Faction color · planet · candidate faction · chunk_id · chunk offset · size. Sourced from real save bytes by string-mining 0x3EA/0x3E9/0x3EB leaves.
                                    </TextBlock>
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Planets}" Margin="6">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,2" Padding="4,3" CornerRadius="2"
                                                            Background="#101020"
                                                            BorderBrush="{Binding FactionBrush}" BorderThickness="0,0,0,1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="14"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                                    Background="{Binding FactionBrush}" VerticalAlignment="Center"
                                                                    HorizontalAlignment="Left"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                                       Foreground="#E8E8F8" FontFamily="Segoe UI" FontWeight="SemiBold"
                                                                       FontSize="11" Margin="6,0,0,0"/>
                                                            <Border Grid.Column="2" Background="{Binding FactionBrush}"
                                                                    CornerRadius="2" Padding="4,1" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding FactionLabel}"
                                                                           Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="3" Text="{Binding ChunkIdHex}"
                                                                       Foreground="#67C8E0" FontFamily="Consolas" FontSize="10" Margin="0,0,6,0"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding OffsetHex}"
                                                                       Foreground="#90A0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,6,0"/>
                                                            <TextBlock Grid.Column="5" Text="{Binding SizeLabel}"
                                                                       Foreground="#A0B0C0" FontSize="10"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 23: Quick Actions (iter 53) -->
            <!-- iter 54: composites are now capability-aware. Per-button badges
                 reflect catalog status; tab-level amber banner appears when any
                 composite mixes LIVE + PHASE 2 PENDING primitives. -->
            <TabItem Header="Quick Actions" ToolTip="{Binding TooltipQuickActions}">
                <Grid DataContext="{Binding QuickActions}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Operator workflow composites — each button fires 2-7 primitive bridge calls in sequence. Status line below shows N/M succeeded; failures are listed by SWFOC_X name."
                               TextWrapping="Wrap" Margin="0,0,0,8"
                               Foreground="{DynamicResource MutedForeground}"/>
                    <Border Grid.Row="1"
                            Background="{DynamicResource WarningBackground}"
                            BorderBrush="{DynamicResource WarningBorderBrush}"
                            BorderThickness="1"
                            Padding="8,6" Margin="0,0,0,8"
                            Visibility="{Binding HasMixedComposite, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding MixedCompositeWarning}"
                                   Foreground="{DynamicResource WarningForeground}"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <StackPanel Grid.Row="2">
                        <GroupBox Header="Cheat workflows" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding OperatorGodMode.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding OperatorGodMode.Tooltip}"/>
                                    </Border>
                                    <Button Content="Operator god mode (GodMode + Heal me + Uncap credits)"
                                            Command="{Binding OperatorGodModeCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="3 calls: SWFOC_GodMode(1) → SWFOC_HealAllLocal() → SWFOC_UncapCredits()"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding DrainEnemies.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding DrainEnemies.Tooltip}"/>
                                    </Border>
                                    <Button Content="Drain enemy credits"
                                            Command="{Binding DrainEnemiesCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="SWFOC_DrainEnemyCredits() — engine zeroes every non-local-human player's credits."/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Visibility workflows" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding RevealGalaxy.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding RevealGalaxy.Tooltip}"/>
                                    </Border>
                                    <Button Content="Reveal galaxy (RevealAll + refresh planets + refresh players)"
                                            Command="{Binding RevealGalaxyCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="3 calls: SWFOC_RevealAll(1) → SWFOC_GetPlanets() → SWFOC_GetAllPlayers(). Galactic tab DataGrid will auto-update via the existing live-state hookup."/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>
                        <!-- iter 64: content-creator workflow shortcuts. -->
                        <GroupBox Header="Content-creator workflows" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding BattleSetup.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding BattleSetup.Tooltip}"/>
                                    </Border>
                                    <Button Content="Battle setup (god + heal + uncap + drain enemies)"
                                            Command="{Binding BattleSetupCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="4 calls: SWFOC_GodMode(1) → SWFOC_HealAllLocal() → SWFOC_UncapCredits() → SWFOC_DrainEnemyCredits(). Operator-side advantage in one click — for content creators who want a curated battle."/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding FilmingSetup.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding FilmingSetup.Tooltip}"/>
                                    </Border>
                                    <Button Content="Filming setup (hide UI + freeze AI + god)"
                                            Command="{Binding FilmingSetupCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="3 live calls: hide UI via DoString → SWFOC_SuspendAiLua('3600') → SWFOC_GodMode(1). Phase-2 permadeath is intentionally omitted."/>
                                </DockPanel>
                                <!-- iter 80: capstone composites tying iter 76 (Combat) / iter 77 (Speed) / iter 78 (HeroLab) presets together. -->
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding TournamentSetup.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding TournamentSetup.Tooltip}"/>
                                    </Border>
                                    <Button Content="Tournament setup (Hard scalars + slow respawn)"
                                            Command="{Binding TournamentSetupCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="3 live calls: SWFOC_SetDamageMultiplierGlobal(1.5) → SWFOC_SetFireRateMultiplierGlobal(1.25) → SWFOC_SetHeroRespawn(15). Global game-speed is omitted because it is Phase 2 pending."/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding SandboxSetup.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding SandboxSetup.Tooltip}"/>
                                    </Border>
                                    <Button Content="Sandbox setup (god + heal + uncap + drain + quick respawn)"
                                            Command="{Binding SandboxSetupCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="5 live calls: GodMode(1) → HealAllLocal() → UncapCredits() → DrainEnemyCredits() → SetHeroRespawn(2.5). Global game-speed is omitted because it is Phase 2 pending."/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding StreamingSetup.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding StreamingSetup.Tooltip}"/>
                                    </Border>
                                    <Button Content="Streaming setup (hide UI + freeze AI + slow respawn)"
                                            Command="{Binding StreamingSetupCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="3 live calls: hide UI via DoString → SWFOC_SuspendAiLua('3600') → SWFOC_SetHeroRespawn(15). Slow-mo is omitted because global game-speed is Phase 2 pending."/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Reset / cleanup workflows">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Border DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                                            Background="{DynamicResource StatusBackground}">
                                        <TextBlock Text="{Binding ResetToggles.Badge}"
                                                   Foreground="{DynamicResource AccentForeground}"
                                                   FontSize="10" FontWeight="SemiBold" ToolTip="{Binding ResetToggles.Tooltip}"/>
                                    </Border>
                                    <Button Content="Reset live global toggles (god/OHK/credits freeze/freeze-AI)"
                                            Command="{Binding ResetTogglesCommand}"
                                            Padding="16,8"
                                            HorizontalAlignment="Left" MinWidth="420"
                                            ToolTip="4 live calls in sequence: SWFOC_GodMode(0), SWFOC_OneHitKill(0), SWFOC_SetCreditsFreezeGlobal(0), SWFOC_SuspendAiLua('0'). Phase-2 toggles are intentionally omitted."/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                    <Border Grid.Row="3" Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                        <TextBlock Text="{Binding LastStatus}"
                                   Foreground="{DynamicResource AccentForeground}"
                                   FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!--
            2026-04-27 (iter 11): bottom status bar. Always visible across
            tabs so the operator knows the bridge connection state without
            navigating to Diagnostics. The colour swatch goes green
            (ConnectedBackground) when Diagnostics.BridgeReady is true and
            red (DisconnectedBackground) otherwise — the existing
            StatusBrush computed property on DiagnosticsTabViewModel handles
            the swap.
        -->
        <Border Grid.Row="2" Margin="0,6,0,0"
                Background="{DynamicResource ChromeBackground}"
                BorderBrush="{DynamicResource BorderBrushBase}"
                BorderThickness="1"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="10" Height="10" CornerRadius="5"
                            VerticalAlignment="Center"
                            Background="{Binding Diagnostics.StatusBrush}"
                            ToolTip="Green = bridge reachable; Red = no probe responses yet."/>
                    <!-- iter 70: bridge-health dot tracking recent failure rate.
                         Distinct from the iter-254 reachability dot above —
                         this one says "calls succeeding" rather than "pipe up". -->
                    <Border Width="10" Height="10" CornerRadius="5"
                            VerticalAlignment="Center" Margin="6,0,0,0"
                            Background="{Binding Diagnostics.BridgeHealthCategory, Converter={StaticResource HealthCategoryToBrush}}"
                            ToolTip="{Binding Diagnostics.BridgeHealthTooltip}"/>
                    <TextBlock Text="  Bridge: " Foreground="{DynamicResource MutedForeground}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Diagnostics.StatusBanner}"
                               Foreground="{DynamicResource AccentForeground}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="700"/>
                </StackPanel>
                <!-- iter 63: capability surface roll-up. Always-visible
                     headline number for the editor's engine-effectiveness
                     ratio. iter 68: tooltip embeds the iter-67 trend line
                     when history exists so operators see Phase 2 progress
                     at hover time. -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CapabilitySurface.SummaryLine}"
                           Foreground="{DynamicResource MutedForeground}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding CapabilitySurfaceTooltip}"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding Diagnostics.PipeName, StringFormat='Pipe: {0}'}"
                           Foreground="{DynamicResource MutedForeground}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontFamily="Consolas, Lucida Console, monospace"/>
            </Grid>
        </Border>
    </Grid>
</Window>
