                                    <TextBlock Text="{Binding FindObjectTypeLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                               ToolTip="{Binding FindObjectTypeLua.Tooltip}"/>
                                    <Button Content="Find planet"
                                            Command="{Binding FindPlanetLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="SWFOC_FindPlanetLua → FindPlanet(name). LIVE — returns engine PlanetWrapper handle. Pairs with FOWReveal partial-reveal workflow."/>
                                    <TextBlock Text="{Binding FindPlanetLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                               ToolTip="{Binding FindPlanetLua.Tooltip}"/>
                                    <Button Content="Find first object"
                                            Command="{Binding FindFirstObjectLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="SWFOC_FindFirstObjectLua → Find_First_Object(type_name). LIVE — returns engine GameObjectWrapper handle for the first instance of that type in the running game."/>
                                    <TextBlock Text="{Binding FindFirstObjectLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                               ToolTip="{Binding FindFirstObjectLua.Tooltip}"/>
                                    <!--
                                        2026-05-05 (iter 206): iter-179 Find_All_Objects_Of_Type
                                        completes the "first / nearest / all" trio with iter-177
                                        FindFirstObject + iter-186 FindNearest. Returns engine
                                        table-handle for further composition.
                                    -->
                                    <Button Content="Find all of type"
                                            Command="{Binding FindAllObjectsOfTypeLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="SWFOC_FindAllObjectsOfTypeLua → Find_All_Objects_Of_Type(type_name). LIVE — returns engine table-handle of EVERY instance of that type. Pair with Find_First_Object (single) and Find_Nearest (closest) for the full discovery trio."/>
                                    <TextBlock Text="{Binding FindAllObjectsOfTypeLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding FindAllObjectsOfTypeLua.Tooltip}"/>
                                </WrapPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Nearest position (Lua): " VerticalAlignment="Center"/>
                                    <TextBox Width="200" Text="{Binding FindNearestPositionLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Lua position expression (e.g. Vector(0, 0, 0))."/>
                                    <TextBlock Text="    Player (Lua): " VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBox Width="160" Text="{Binding FindNearestPlayerLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Lua expression for the searching player (e.g. Find_Player(&quot;REBEL&quot;))."/>
                                    <Button Content="Find nearest"
                                            Command="{Binding FindNearestLuaCommand}"
                                            Margin="12,0,0,0" Padding="8,3"
                                            ToolTip="SWFOC_FindNearestLua → Find_Nearest(type, position, player). LIVE 3-arg getter. Reuses Type field above. Workflow: Find_Nearest(Find_Object_Type('AT_AT'), pos, Get_Local_Player())."/>
                                    <TextBlock Text="{Binding FindNearestLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"
                                               ToolTip="{Binding FindNearestLua.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                    <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <!-- =================================================== TAB 13: Galactic (Unit D) -->
            <TabItem Header="Galactic" ToolTip="{Binding TooltipGalactic}">
                <!-- iter 57: per-button capability badges + tab-level Phase-2-pending banner.
                     Galactic mixes LIVE (RevealAll) with PHASE 2 PENDING (refresh, owner change,
                     convert/kick, diplomacy, story-arrival spawn). -->
                <Grid DataContext="{Binding Galactic}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{DynamicResource WarningBackground}"
                            BorderBrush="{DynamicResource WarningBorderBrush}"
                            BorderThickness="1"
                            Padding="8,6" Margin="0,0,0,8"
                            Visibility="{Binding HasPhase2PendingAction, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Phase2PendingWarning}"
                                   Foreground="{DynamicResource WarningForeground}"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
