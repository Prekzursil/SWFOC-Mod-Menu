                                            Command="{Binding ChangeOwnerConvertCommand}"
                                            ToolTip="Disabled: SWFOC_ChangePlanetOwnerWithMode(convert) is PHASE 2 PENDING until a live galactic-owner hook exists."/>
                                    <TextBlock Text="{Binding ChangeOwnerConvert.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ChangeOwnerConvert.Tooltip}"/>
                                </StackPanel>
                                <StackPanel>
                                    <Button Content="Flip &amp; destroy"
                                            Command="{Binding ChangeOwnerPureKickCommand}"
                                            ToolTip="Disabled: SWFOC_ChangePlanetOwnerWithMode(pure_kick) is PHASE 2 PENDING until a live galactic-owner hook exists."/>
                                    <TextBlock Text="{Binding ChangeOwnerPureKick.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ChangeOwnerPureKick.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Row="4" Header="Diplomacy">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Slot A: "/>
                            <TextBox Width="100" Text="{Binding DiplomacySlotA, UpdateSourceTrigger=PropertyChanged}"/>
