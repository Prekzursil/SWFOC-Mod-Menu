                        </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- =================================================== TAB 11: Speed (Unit D) -->
            <!-- iter 56: per-button capability badges + tab-level Phase-2-pending banner. -->
            <TabItem Header="Speed" ToolTip="{Binding TooltipSpeed}">
                <ScrollViewer DataContext="{Binding Speed}" Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{DynamicResource WarningBackground}"
