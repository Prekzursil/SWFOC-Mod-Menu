                                       Foreground="{DynamicResource WarningForeground}"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <GroupBox Header="Global game speed">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Speed (1.0 = real-time, 0 = paused): "/>
                                    <TextBox Width="80" Text="{Binding GlobalGameSpeed, UpdateSourceTrigger=PropertyChanged}"/>
