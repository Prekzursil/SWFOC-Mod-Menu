                                    <TextBlock Text="{Binding HealUnitLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                               ToolTip="{Binding HealUnitLua.Tooltip}"/>
                                    <Button Content="Take damage"
                                            Command="{Binding TakeDamageLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="Calls (unit):Take_Damage(amount). Routes through Take_Damage_Outer chokepoint, so the global multiplier applies."/>
                                    <TextBlock Text="{Binding TakeDamageLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                               ToolTip="{Binding TakeDamageLua.Tooltip}"/>
                                    <Button Content="Set damage mod"
                                            Command="{Binding SetDamageModifierLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="Calls (unit):Set_Damage_Modifier(mult). Per-unit OUTGOING damage multiplier (different surface from the GLOBAL multiplier above)."/>
                                    <TextBlock Text="{Binding SetDamageModifierLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                               ToolTip="{Binding SetDamageModifierLua.Tooltip}"/>
                                    <Button Content="Set RoF mod"
                                            Command="{Binding SetRateOfFireModifierLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="Calls (unit):Set_Rate_Of_Fire_Modifier(mult). Closes the SetFireRate operator gap at the per-unit level."/>
                                    <TextBlock Text="{Binding SetRateOfFireModifierLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding SetRateOfFireModifierLua.Tooltip}"/>
                                </WrapPanel>
                                <Separator Margin="0,8,0,8"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="{DynamicResource MutedForeground}"
                                           Margin="0,0,0,4"
                                           Text="Cinematic helper: Suspend_AI(seconds) pauses the AI player's decision loop. Pairs with Lock_Controls + the cinematic camera quad (Start / End / Set_Key / Transition_Key on the Camera &amp; Debug tab) for full battle-pause cinematic recording."/>
                                <TextBox Text="{Binding SuspendAiSecondsLuaExpr, UpdateSourceTrigger=PropertyChanged}"
