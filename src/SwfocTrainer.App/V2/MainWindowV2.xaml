                                <TextBlock Text="{Binding ReadHasAttackTargetLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ReadHasAttackTargetLuaAction.Tooltip}"/>
                                <Button Content="Engines online?"
                                        Command="{Binding ReadAreEnginesOnlineLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="SWFOC_AreEnginesOnlineLua → composes (unit):Are_Engines_Online() and returns 'true'/'false'. Iter-168 LIVE wire — relevant for ships in tactical battles."/>
                                <TextBlock Text="{Binding ReadAreEnginesOnlineLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding ReadAreEnginesOnlineLuaAction.Tooltip}"/>
                                <!-- 2026-05-05 (iter 197): 6 more read-side buttons surfacing iter-171/172 wires. Same UnitLuaExpr field as the 4 iter-191 buttons above. -->
                                <Button Content="Parent obj"
                                        Command="{Binding ReadParentObjectLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Parent_Object(). Returns parent handle for nested objects (e.g. garrisoned units)."/>
                                <TextBlock Text="{Binding ReadParentObjectLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ReadParentObjectLuaAction.Tooltip}"/>
                                <Button Content="Attack target"
                                        Command="{Binding ReadAttackTargetLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Attack_Target(). Returns current attack target handle. Pair with Has attack target? predicate."/>
                                <TextBlock Text="{Binding ReadAttackTargetLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ReadAttackTargetLuaAction.Tooltip}"/>
                                <Button Content="Damage mod"
                                        Command="{Binding ReadDamageModifierLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Damage_Modifier(). Read-after-write pair with Set damage mod button on Combat tab."/>
                                <TextBlock Text="{Binding ReadDamageModifierLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ReadDamageModifierLuaAction.Tooltip}"/>
                                <Button Content="Contained count"
                                        Command="{Binding ReadContainedObjectCountLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Contained_Object_Count(). Numeric count complement to 'Read garrison' button on UnitControl tab."/>
                                <TextBlock Text="{Binding ReadContainedObjectCountLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ReadContainedObjectCountLuaAction.Tooltip}"/>
                                <Button Content="Behavior id"
                                        Command="{Binding ReadBehaviorIdLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Behavior_ID(). Returns the unit's current behavior identifier for AI debugging."/>
                                <TextBlock Text="{Binding ReadBehaviorIdLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ReadBehaviorIdLuaAction.Tooltip}"/>
                                <Button Content="RoF mod"
                                        Command="{Binding ReadRateOfFireModifierLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Rate_Of_Fire_Modifier(). Read-after-write pair with Set RoF mod button on Combat tab."/>
                                <TextBlock Text="{Binding ReadRateOfFireModifierLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding ReadRateOfFireModifierLuaAction.Tooltip}"/>
                            </WrapPanel>
                            <!--
                                2026-05-05 (iter 198): arg-getter extension for
                                iter-173 wires. Each takes a 2nd arg (predicate
                                name or target unit Lua expr). Shared UnitArgExpr
                                field below feeds all 4 buttons.
                            -->
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Predicate / target arg: type ability/property/category name OR a target unit Lua expression. Examples: &quot;SCAN_BOMBS&quot;, &quot;Hero&quot;, Find_First_Object(&quot;Rebel_Tank&quot;)."/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Arg:" Width="50" VerticalAlignment="Center"/>
                                <TextBox Width="380"
                                         Text="{Binding UnitArgExpr, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas, Lucida Console, monospace"/>
                            </StackPanel>
                            <WrapPanel>
                                <Button Content="Is ability active?"
                                        Command="{Binding IsAbilityActiveLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Is_Ability_Active(name). Read-after-write pair with ActivateAbility writer."/>
                                <TextBlock Text="{Binding IsAbilityActiveLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding IsAbilityActiveLuaAction.Tooltip}"/>
                                <Button Content="Has property?"
                                        Command="{Binding HasPropertyLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Has_Property(prop). Per docs/lua-api.md GameObjectWrapper Queries section."/>
                                <TextBlock Text="{Binding HasPropertyLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding HasPropertyLuaAction.Tooltip}"/>
                                <Button Content="Is category?"
                                        Command="{Binding IsCategoryLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Is_Category(cat). Useful for Hero/Infantry/Vehicle filtering workflows."/>
                                <TextBlock Text="{Binding IsCategoryLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding IsCategoryLuaAction.Tooltip}"/>
                                <Button Content="Get distance"
                                        Command="{Binding GetDistanceLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Distance(target). Useful for AI/scripting workflows (range-check before attack)."/>
                                <TextBlock Text="{Binding GetDistanceLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding GetDistanceLuaAction.Tooltip}"/>
                            </WrapPanel>
                            <Separator Margin="0,8,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="Cross-receiver arg-getters: receiver Lua expression goes into UnitLuaExpr above, second arg into Arg field. Receiver type varies per wire — see button tooltips. Helper is shape-agnostic, works for unit / player / TaskForce."/>
                            <WrapPanel>
                                <Button Content="Get bone position"
                                        Command="{Binding GetBonePositionLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Get_Bone_Position(bone-name). Returns position handle for the named model bone. Receiver: unit. Useful for cinematic camera anchoring."/>
                                <TextBlock Text="{Binding GetBonePositionLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding GetBonePositionLuaAction.Tooltip}"/>
                                <Button Content="Contains object type?"
                                        Command="{Binding ContainsObjectTypeLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (unit):Contains_Object_Type(child-type). Returns bool. Receiver: unit. Useful for garrison-content queries."/>
                                <TextBlock Text="{Binding ContainsObjectTypeLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding ContainsObjectTypeLuaAction.Tooltip}"/>
                                <Button Content="Get space station level"
                                        Command="{Binding GetSpaceStationLevelLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (player):Get_Space_Station_Level(planet). Returns numeric level (0-5). Receiver: PLAYER (type Find_Player(...) into UnitLuaExpr). Galactic AI tech-progression check."/>
                                <TextBlock Text="{Binding GetSpaceStationLevelLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           ToolTip="{Binding GetSpaceStationLevelLuaAction.Tooltip}"/>
                                <Button Content="Get type of unit at index"
                                        Command="{Binding GetTypeOfUnitLuaCommand}"
                                        Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Get_Type_Of_Unit(idx). Returns GameObjectType handle. Receiver: TASKFORCE (type a TaskForce handle into UnitLuaExpr). First TaskForce wire shipped via the unit-getter-arg helper."/>
                                <TextBlock Text="{Binding GetTypeOfUnitLuaAction.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding GetTypeOfUnitLuaAction.Tooltip}"/>
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Row="2" Header="Live snapshot">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Address (hex):" Foreground="{DynamicResource MutedForeground}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SnapshotAddrHex}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Owner slot:" Foreground="{DynamicResource MutedForeground}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SnapshotOwner}" Foreground="{DynamicResource AccentForeground}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Hull:" Foreground="{DynamicResource MutedForeground}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SnapshotHull}" Foreground="{DynamicResource AccentForeground}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Invuln flag:" Foreground="{DynamicResource MutedForeground}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SnapshotInvuln}" Foreground="{DynamicResource AccentForeground}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Prevent death:" Foreground="{DynamicResource MutedForeground}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SnapshotPreventDeath}" Foreground="{DynamicResource AccentForeground}"/>
                        </Grid>
                    </GroupBox>
                    <Border Grid.Row="3" Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- =================================================== TAB 10: Combat (Unit D) -->
            <TabItem Header="Combat" ToolTip="{Binding TooltipCombat}">
                <!-- iter 56: per-button capability badges + tab-level Phase-2-pending banner.
                     Replaces the misleading "Toggles (LIVE — engine effect verified)" header
                     since OHK-AttackPower + Area-Damage are actually PHASE 2 PENDING. -->
                <ScrollViewer DataContext="{Binding Combat}" Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{DynamicResource WarningBackground}"
                                BorderBrush="{DynamicResource WarningBorderBrush}"
                                BorderThickness="1"
                                Padding="8,6" Margin="0,0,0,8"
                                Visibility="{Binding HasPhase2PendingAction, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Phase2PendingWarning}"
                                       Foreground="{DynamicResource WarningForeground}"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <GroupBox Header="Scope">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Slot: "/>
                                <TextBox Width="80" Text="{Binding Slot, UpdateSourceTrigger=PropertyChanged}" ToolTip="-1 = local; 0..N = specific slot"/>
                                <TextBlock Text="    Selected obj_addr (decimal): " Margin="12,0,0,0"/>
                                <TextBox Width="180" Text="{Binding SelectedObjAddr, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Toggles">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Button   Grid.Row="0" Grid.Column="0" Content="Toggle God Mode" Command="{Binding ToggleGodModeCommand}"
                                          ToolTip="SWFOC_GodMode → flip the engine-level god-mode flag for the operator's local slot. State indicator on the right shows current on/off."/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text=" "/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ToggleGodMode.Badge}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" ToolTip="{Binding ToggleGodMode.Tooltip}"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding IsGodModeEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                                <Button   Grid.Row="1" Grid.Column="0" Content="Toggle One Hit Kill" Command="{Binding ToggleOhkCommand}"
                                          ToolTip="SWFOC_OneHitKill → outgoing damage from your units is amplified to one-shot any target."/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ToggleOhk.Badge}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" ToolTip="{Binding ToggleOhk.Tooltip}"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding IsOhkEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                                <Button   Grid.Row="2" Grid.Column="0" Content="Toggle OHK Attack Power" Command="{Binding ToggleOhkAttackPowerCommand}" ToolTip="PHASE 2 PENDING — replay-only"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ToggleOhkAttackPower.Badge}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" ToolTip="{Binding ToggleOhkAttackPower.Tooltip}"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding IsOhkAttackPowerEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                                <Button   Grid.Row="3" Grid.Column="0" Content="Toggle Area Damage" Command="{Binding ToggleAreaDamageCommand}" ToolTip="PHASE 2 PENDING — replay-only"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ToggleAreaDamage.Badge}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource MutedForeground}"
                                           VerticalAlignment="Center" ToolTip="{Binding ToggleAreaDamage.Tooltip}"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" Text="    state: " Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding IsAreaDamageEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="Scalars">
                            <StackPanel>
                                <!--
                                    2026-04-27: prominent REPLAY-ONLY banner. The
                                    GroupBox header text was easy to miss; operators
                                    were thinking these scalars worked live when
                                    they only mirror through the replay harness.
                                    Borrows WarningBackground / WarningForeground
                                    from the theme dictionaries (amber on dark/light).
                                -->
                                <Border Background="{DynamicResource WarningBackground}"
                                        BorderBrush="{DynamicResource WarningBorderBrush}"
                                        BorderThickness="1" CornerRadius="2"
                                        Padding="8,4" Margin="0,0,0,6">
                                    <TextBlock Text="⚠  REPLAY MIRROR ONLY  —  not yet live in the running game (PHASE 2 PENDING)"
                                               Foreground="{DynamicResource WarningForeground}"
                                               FontWeight="Bold" FontSize="11"/>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Damage mult: "/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding DamageMultiplier, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                                        <StackPanel>
                                            <Button Content="Apply (per-slot)" Command="{Binding SetDamageMultiplierCommand}"
                                                    ToolTip="Per-slot damage scalar (PHASE 2 PENDING — attacker context unavailable at Take_Damage)"/>
                                            <TextBlock Text="{Binding SetDamageMultiplier.Badge}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedForeground}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetDamageMultiplier.Tooltip}"/>
                                        </StackPanel>
                                        <StackPanel Margin="6,0,0,0">
                                            <Button Content="Apply (GLOBAL)" Command="{Binding SetDamageMultiplierGlobalCommand}"
                                                    ToolTip="Take_Damage_Outer detour scales damageParams[0] for ALL incoming damage"/>
                                            <TextBlock Text="{Binding SetDamageMultiplierGlobal.Badge}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedForeground}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetDamageMultiplierGlobal.Tooltip}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Shield value: "/>
                                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding ShieldValue, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Grid.Row="1" Grid.Column="2">
                                        <Button Content="Apply" Command="{Binding SetUnitShieldCommand}" ToolTip="Targets SelectedObjAddr"/>
                                        <TextBlock Text="{Binding SetUnitShield.Badge}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForeground}"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetUnitShield.Tooltip}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Fire rate mult: "/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding FireRateMultiplier, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                        <StackPanel>
                                            <Button Content="Apply (per-slot)" Command="{Binding SetFireRateCommand}"
                                                    ToolTip="Per-slot fire-rate scalar (PHASE 2 PENDING — receiver-context unavailable at WeaponTick)"/>
                                            <TextBlock Text="{Binding SetFireRate.Badge}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedForeground}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetFireRate.Tooltip}"/>
                                        </StackPanel>
                                        <!-- iter 227: global fire rate multiplier — sibling to iter-96 damage GLOBAL.
                                             LIVE via WeaponTick @ 0x387010 MinHook detour (closes A1.3 after 124-day
                                             deferral). Caveat: mult=0 effectively freezes weapon time — use Suspend_AI
                                             button on this tab for proper AI pause. Clamp [0.0, 100.0]. -->
                                        <StackPanel Margin="6,0,0,0">
                                            <Button Content="Apply (GLOBAL)" Command="{Binding SetFireRateMultiplierGlobalCommand}"
                                                    ToolTip="WeaponTick MinHook detour scales dt arg for ALL weapon cooldowns. Caveat: mult=0 freezes weapons; use Suspend_AI for proper pause. Clamped [0.0, 100.0]."/>
                                            <TextBlock Text="{Binding SetFireRateMultiplierGlobal.Badge}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedForeground}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetFireRateMultiplierGlobal.Tooltip}"/>
                                        </StackPanel>
                                        <StackPanel Margin="6,0,0,0">
                                            <Button Content="Read (GLOBAL)" Command="{Binding GetFireRateMultiplierGlobalCommand}"
                                                    ToolTip="Read-back the current g_fireRateMult_global value the bridge has stored."/>
                                            <TextBlock Text="{Binding GetFireRateMultiplierGlobal.Badge}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedForeground}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding GetFireRateMultiplierGlobal.Tooltip}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Target filter: "/>
                                    <!--
                                        2026-04-27: replaced opaque 3-bit
                                        bitmask textbox (0x1/0x2/0x4) with
                                        per-bit checkboxes. The underlying
                                        TargetFilterBitmask int still flows
                                        through the same state machine and
                                        Lua command — we just give the
                                        operator a humane input surface.
                                    -->
                                    <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                                Orientation="Horizontal">
                                        <CheckBox Content="ENEMY"
                                                  IsChecked="{Binding FilterIncludesEnemy}"
                                                  Margin="0,0,8,0"
                                                  ToolTip="Include enemy units in the targeting filter (bit 0x1)."/>
                                        <CheckBox Content="FRIENDLY"
                                                  IsChecked="{Binding FilterIncludesFriendly}"
                                                  Margin="0,0,8,0"
                                                  ToolTip="Include friendly units (bit 0x2)."/>
                                        <CheckBox Content="NEUTRAL"
                                                  IsChecked="{Binding FilterIncludesNeutral}"
                                                  Margin="0,0,8,0"
                                                  ToolTip="Include neutral units (bit 0x4)."/>
                                        <StackPanel Margin="8,0,0,0">
                                            <Button Content="Apply"
                                                    Command="{Binding SetTargetFilterCommand}"/>
                                            <TextBlock Text="{Binding SetTargetFilter.Badge}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MutedForeground}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetTargetFilter.Tooltip}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <!--
                                    iter 76: difficulty presets. One-click
                                    damage + fire-rate combos for
                                    streaming/recording use cases. Same
                                    pattern as iter-12 Speed presets;
                                    underlying scalars are PHASE 2 PENDING
                                    so the warning banner above this
                                    GroupBox already informs the operator.
                                -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Presets:" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <Button Content="Easy"
                                            Command="{Binding ApplyEasyPresetCommand}"
                                            Margin="0,0,4,0"
