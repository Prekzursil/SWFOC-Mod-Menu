                                             Text="{Binding CameraTargetExpr, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas, Lucida Console, monospace"
                                             ToolTip="Lua expression for Camera_To_Follow / Rotate_Camera_To. Examples: Find_First_Object(&quot;Empire_AT_AT&quot;), Find_Player(&quot;REBEL&quot;):Get_Hero()"/>
