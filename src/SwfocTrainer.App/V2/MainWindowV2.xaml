                                         Margin="0,0,0,6"
                                         ToolTip="Numeric duration in seconds (e.g. 5)"/>
                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="Suspend AI"
                                            Command="{Binding SuspendAiLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="Calls Suspend_AI(seconds). Pauses AI decision-making for the given duration. Cinematic helper. Uses SuspendAiSecondsLuaExpr field."/>
                                    <TextBlock Text="{Binding SuspendAiLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding SuspendAiLua.Tooltip}"/>
                                </WrapPanel>
                            </StackPanel>
                        </GroupBox>
                        <!-- 2026-05-07 (iter 339): Hardpoint Inspector — closes iter-338 deferred XAML layer.
                             SWFOC_GetHardpoints LIVE wire (iter-281; RequiresLiveSwfoc).
                             Operator types unit obj_addr, clicks Refresh, ListBox shows hardpoint
                             vector (index, child_addr, hp). Defers icon resolution to iter-340+. -->
                        <GroupBox Header="Hardpoint Inspector (SWFOC_GetHardpoints; RequiresLiveSwfoc)"
                                  Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Unit obj_addr (hex e.g. 0x12345678 or decimal). Use Inspector tab Copy obj_addr button."
