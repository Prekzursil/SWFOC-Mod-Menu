                        <StackPanel Margin="0,0,8,0">
                            <Button Content="Toggle reveal-all" Command="{Binding ToggleRevealAllCommand}"
                                    ToolTip="SWFOC_RevealAll → flip the reveal-all flag on the FogOfWar manager so the operator sees every planet's tech / owner. Toggle off to restore."/>
                            <TextBlock Text="{Binding ToggleRevealAll.Badge}"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedForeground}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ToggleRevealAll.Tooltip}"/>
                        </StackPanel>
                        <TextBlock Text="    reveal-all: " Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding IsRevealAllEnabled}" Foreground="{DynamicResource AccentForeground}" VerticalAlignment="Center"/>
