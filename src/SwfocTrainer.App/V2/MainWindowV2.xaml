                                <StackPanel Margin="10,0,0,0">
                                    <Button Content="Change" Command="{Binding ChangeOwnerCommand}"
                                            ToolTip="Disabled: SWFOC_ChangePlanetOwner is PHASE 2 PENDING until a live galactic-owner hook exists."/>
