                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Planet" Binding="{Binding PlanetId}" Width="200"/>
                            <DataGridTextColumn Header="Owner"  Binding="{Binding OwnerFaction}" Width="160"/>
                            <DataGridTextColumn Header="Tech"   Binding="{Binding TechLevel}" Width="80"/>
