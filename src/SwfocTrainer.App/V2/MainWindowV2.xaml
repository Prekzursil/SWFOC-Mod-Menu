                                <TextBox Text="{Binding SpawnPlayerLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas, Lucida Console, monospace" Margin="0,0,0,4"/>
                                <TextBlock Text="Type Lua (e.g. Find_Object_Type(&quot;Rebel_Trooper_Squad&quot;)):" FontSize="11"/>
                                <TextBox Text="{Binding SpawnTypeLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas, Lucida Console, monospace" Margin="0,0,0,4"/>
                                <TextBlock Text="Position Lua (e.g. Create_Position(0, 0, 0)):" FontSize="11"/>
                                <TextBox Text="{Binding SpawnPositionLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas, Lucida Console, monospace" Margin="0,0,0,6"/>
                                <Button Content="Spawn (Lua, LIVE) →"
                                        Command="{Binding SpawnUnitLuaCommand}"
                                        HorizontalAlignment="Left" Padding="12,4"
                                        ToolTip="Calls SWFOC_SpawnUnitLua(player, type, position) via DoString. Genuinely spawns a unit at the engine level, unlike SWFOC_SpawnUnit which is replay-mirror-only."/>
                                <TextBlock Text="{Binding SpawnUnitLua.Badge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}"
                                           HorizontalAlignment="Left" Margin="0,2,0,0"
                                           ToolTip="{Binding SpawnUnitLua.Tooltip}"/>
                                <!--
                                    2026-05-05 (iter 195): iter-185 spawn variants.
                                    Reinforce/SpawnFromPool share the (player, type, position)
                                    shape with iter-119 SpawnUnitLua. CreateGenericObject
                                    has a DIFFERENT engine param order — clearly labeled.
                                -->
                                <Separator Margin="0,8,0,8"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="{DynamicResource MutedForeground}"
                                           Margin="0,0,0,4"
                                       Text="Spawn variants: the 3 fields above feed all of these. Reinforce + Pool spawn share Spawn_Unit's param order. CreateGenericObject's engine API takes (type, position, player) — the dispatcher reorders for you, so the 3 fields above stay player-first as labelled."/>
                                <WrapPanel>
                                    <Button Content="Reinforce unit (Lua)"
                                            Command="{Binding ReinforceUnitLuaCommand}"
                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="Reinforcement-pool spawn. Calls SWFOC_ReinforceUnitLua(player, type, position). Alternative entrypoint to Spawn_Unit; uses the engine's reinforcement-pool path."/>
