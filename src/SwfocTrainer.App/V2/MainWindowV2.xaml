                                <StackPanel Margin="10,0,0,0">
                                    <Button Content="Reveal map"
                                            Command="{Binding FOWRevealAllLuaCommand}"
                                            ToolTip="SWFOC_FOWRevealAllLua → FOWManager.Reveal_All(player). LIVE — reveals the entire galactic map for the named player. Useful for cinematic / debug workflows."/>
                                    <TextBlock Text="{Binding FOWRevealAllLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding FOWRevealAllLua.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <Button Content="Restore fog"
                                            Command="{Binding FOWUndoRevealAllLuaCommand}"
                                            ToolTip="SWFOC_FOWUndoRevealAllLua → FOWManager.Undo_Reveal_All(player). LIVE — pair with 'Reveal map' to toggle FOW on/off."/>
                                    <TextBlock Text="{Binding FOWUndoRevealAllLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding FOWUndoRevealAllLua.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Position Lua: " VerticalAlignment="Center"/>
                                <TextBox Width="240" Text="{Binding FOWPositionLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Lua expression evaluating to a position (e.g. FindPlanet(&quot;Yavin&quot;):Get_Position())."/>
                                <TextBlock Text="    Radius: " Margin="12,0,0,0" VerticalAlignment="Center"/>
                                <TextBox Width="80" Text="{Binding FOWRadiusLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Lua number (typical: 500 for a planet-scale partial reveal)."/>
                                <StackPanel Margin="10,0,0,0">
                                    <Button Content="Reveal at position"
                                            Command="{Binding FOWRevealLuaCommand}"
                                            ToolTip="SWFOC_FOWRevealLua → FOWManager.Reveal(player, position, radius). LIVE — partial-area reveal complement to 'Reveal map'. Wraps the global-3-arg helper."/>
                                    <TextBlock Text="{Binding FOWRevealLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding FOWRevealLua.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                            <Separator Margin="0,12,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource MutedForeground}"
                                       Margin="0,0,0,4"
                                       Text="TaskForce write-side mega-batch: 8 wires covering full TaskForce surface — movement, reinforcement, combat orders, AI flags. Type TaskForce handle into the first field; per-button secondary arg goes into the Target field (target unit / position / planet / unit-type). Set_As_Goal_System_Removable uses a hardcoded-bool on/off pair."/>
                            <TextBox Text="{Binding TaskForceLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,4"
                                     ToolTip="TaskForce Lua expression (e.g. Find_TaskForce(&quot;MyForce&quot;) or any TaskForce handle)"/>
                            <TextBox Text="{Binding TaskForceTargetLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Lucida Console, monospace"
                                     Margin="0,0,0,6"
                                     ToolTip="Target/planet/unit-type Lua expression (semantically polymorphic — depends on which button is clicked)"/>
                            <WrapPanel>
                                <Button Content="Move to" Command="{Binding TaskForceMoveToLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Move_To(target). Distinct from unit-receiver SWFOC_MoveToLua."/>
                                <TextBlock Text="{Binding TaskForceMoveToLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Reinforce" Command="{Binding TaskForceReinforceLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Reinforce(type). Adds a unit type to the reinforcement queue."/>
                                <TextBlock Text="{Binding TaskForceReinforceLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Release reinforcements" Command="{Binding TaskForceReleaseReinforcementsLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Release_Reinforcements(). No-arg. Releases held reinforcements (SpaceTaskForce)."/>
                                <TextBlock Text="{Binding TaskForceReleaseReinforcementsLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Launch units" Command="{Binding TaskForceLaunchUnitsLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Launch_Units(planet). Launches a galactic task force toward a planet."/>
                                <TextBlock Text="{Binding TaskForceLaunchUnitsLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Attack target" Command="{Binding TaskForceAttackTargetLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Attack_Target(target). TaskForce-receiver variant of unit-receiver Attack_Target."/>
                                <TextBlock Text="{Binding TaskForceAttackTargetLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Guard target" Command="{Binding TaskForceGuardTargetLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Guard_Target(target). SpaceTaskForce-only."/>
                                <TextBlock Text="{Binding TaskForceGuardTargetLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Land units" Command="{Binding TaskForceLandUnitsLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Land_Units(planet). GalacticTaskForce complement to Launch_Units."/>
                                <TextBlock Text="{Binding TaskForceLandUnitsLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Goal-system-removable: on" Command="{Binding TaskForceSetAsGoalSystemRemovableOnLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Set_As_Goal_System_Removable(true). AI goal-cleanup flag."/>
                                <Button Content="Goal-system-removable: off" Command="{Binding TaskForceSetAsGoalSystemRemovableOffLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Set_As_Goal_System_Removable(false). Disables AI goal-cleanup."/>
                                <TextBlock Text="{Binding TaskForceSetAsGoalSystemRemovableOnLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Move to target" Command="{Binding TaskForceMoveToTargetLuaCommand}" Margin="0,0,6,0" Padding="8,3"
                                        ToolTip="Calls (taskforce):Move_To_Target(target). TaskForceClass-only method distinct from Move_To (which takes a position). Uses TaskForceLuaExpr + TaskForceTargetLuaExpr fields."/>
                                <TextBlock Text="{Binding TaskForceMoveToTargetLuaAction.Badge}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForeground}" VerticalAlignment="Center"/>
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>
                    <Border Grid.Row="7" Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <!-- =================================================== TAB 14: Hero Lab (Unit D) -->
            <!-- iter 57: per-button capability badges + tab-level Phase-2-pending banner. -->
            <TabItem Header="Hero Lab" ToolTip="{Binding TooltipHeroLab}">
                <Grid DataContext="{Binding HeroLab}" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{DynamicResource WarningBackground}"
                            BorderBrush="{DynamicResource WarningBorderBrush}"
                            BorderThickness="1"
                            Padding="8,6" Margin="0,0,0,8"
                            Visibility="{Binding HasPhase2PendingAction, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Phase2PendingWarning}"
                                   Foreground="{DynamicResource WarningForeground}"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel>
                            <Button Content="Refresh heroes" Command="{Binding RefreshHeroesCommand}" HorizontalAlignment="Left"
                                    ToolTip="SWFOC_ListHeroes → enumerate every hero in the current battle / galactic state and populate the DataGrid below."/>
                            <TextBlock Text="{Binding RefreshHeroes.Badge}"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedForeground}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding RefreshHeroes.Tooltip}"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- iter 318: bind to HeroRows (parallel collection with IconPath)
                         instead of Heroes so we can render an in-game hero portrait
                         next to each row. HeroRows mirrors Heroes 1:1 in count + order;
                         IconPath is null when no resolver is wired OR the operator
                         hasn't extracted the portrait DDS yet — null binding hides
                         the Image control gracefully (no broken-image placeholder). -->
                    <DataGrid Grid.Row="2" ItemsSource="{Binding HeroRows}" AutoGenerateColumns="False"
                              IsReadOnly="True" Background="{DynamicResource ChromeBackground}"
                              Foreground="{DynamicResource TextForeground}" GridLinesVisibility="None"
                              RowHeight="72">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="76">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding IconPath}"
                                               Width="64" Height="64"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding TypeName}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="addr"     Binding="{Binding ObjAddr, StringFormat=X}" Width="140"/>
                            <DataGridTextColumn Header="type"     Binding="{Binding TypeName}" Width="200"/>
                            <DataGridTextColumn Header="owner"    Binding="{Binding OwnerSlot}" Width="60"/>
                            <DataGridTextColumn Header="alive"    Binding="{Binding Alive}" Width="60"/>
                            <!--
                                2026-04-27: human-readable respawn column.
                                Computed from RespawnRemainingMs + RespawnEnabled
                                so "5000" → "5.0 sec", >=60s → "1 min 30 sec",
                                disabled → "—". Operator no longer has to
                                mentally divide by 1000 every glance.
                                iter-318: HeroRowWithPortrait mirrors HeroRow's
                                RespawnRemainingDisplay computed property exactly
                                so this binding still resolves correctly after
                                the ItemsSource flip.
                            -->
                            <DataGridTextColumn Header="respawn" Binding="{Binding RespawnRemainingDisplay}" Width="120"/>
                            <DataGridTextColumn Header="enabled"  Binding="{Binding RespawnEnabled}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GroupBox Grid.Row="3" Header="Hero actions" Margin="0,8,0,0">
                        <StackPanel>
                            <!--
                                Hero Lab capability truth:
                                - Respawn routes through live global SWFOC_SetHeroRespawn.
                                - Kill / Revive / EditStat are live-backed.
                                - ListHeroes and per-hero permadeath remain Phase 2 pending.
                            -->
                            <Border Background="{DynamicResource WarningBackground}"
                                    BorderBrush="{DynamicResource WarningBorderBrush}"
                                    BorderThickness="1" CornerRadius="2"
                                    Padding="8,4" Margin="0,0,0,6">
                                <TextBlock Text="Permadeath is PHASE 2 and disabled. Respawn uses the live global default. Kill, Revive, and Edit-stat are live-backed."
                                           Foreground="{DynamicResource WarningForeground}"
                                           FontWeight="Bold" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Selected addr (decimal): "/>
                                <TextBox Width="180" Text="{Binding SelectedHeroAddr, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="    permadeath: " Margin="12,0,0,0" Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Text="{Binding IsPermadeathEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Custom respawn ms: " VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBox Width="80" Text="{Binding CustomRespawnMs, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top"/>
                                <StackPanel Margin="10,0,0,0">
                                    <Button Content="Set respawn" Command="{Binding SetRespawnCommand}"
                                            ToolTip="SWFOC_SetHeroRespawn → apply Custom respawn ms as the global hero respawn default."/>
                                    <TextBlock Text="{Binding SetRespawn.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetRespawn.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="4,0,0,0">
                                    <Button Content="Toggle permadeath" Command="{Binding TogglePermadeathCommand}"
                                            ToolTip="Disabled: SWFOC_SetPermadeath is PHASE 2 PENDING until a per-hero live hook exists."/>
                                    <TextBlock Text="{Binding TogglePermadeath.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding TogglePermadeath.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="4,0,0,0">
                                    <Button Content="Kill" Command="{Binding KillHeroCommand}"/>
                                    <TextBlock Text="{Binding KillHero.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding KillHero.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="4,0,0,0">
                                    <Button Content="Revive" Command="{Binding ReviveHeroCommand}"/>
                                    <TextBlock Text="{Binding ReviveHero.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ReviveHero.Tooltip}"/>
                                </StackPanel>
                                <!--
                                    2026-04-27: mass-respawn composite —
                                    walks every loaded hero row and fires
                                    SWFOC_ReviveUnit per addr. Roll-up
                                    feedback ("revived 5 hero(es)" / errors).
                                -->
                                <StackPanel Margin="12,0,0,0">
                                    <Button Content="Revive ALL"
                                            Command="{Binding ReviveAllHeroesCommand}"
                                            FontWeight="Bold"
                                            Background="{DynamicResource ConnectedBackground}"
                                            Foreground="White"
                                            ToolTip="Revive every hero currently loaded in the DataGrid (must Refresh first)."/>
                                    <TextBlock Text="{Binding ReviveAllHeroes.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ReviveAllHeroes.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- iter 78: respawn-time presets — sets CustomRespawnMs and fires live global SetRespawn. -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Respawn presets:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Content="Quick (2.5s)" Command="{Binding ApplyQuickRespawnCommand}"
                                        ToolTip="One-click: global hero respawn = 2500ms (arena/practice — fast hero rotation)" Margin="0,0,4,0"/>
                                <Button Content="Normal (5s)" Command="{Binding ApplyNormalRespawnCommand}"
                                        ToolTip="One-click: global hero respawn = 5000ms (canonical default)" Margin="0,0,4,0"/>
                                <Button Content="Slow (15s)" Command="{Binding ApplySlowRespawnCommand}"
                                        ToolTip="One-click: global hero respawn = 15000ms (punishment-flavored)" Margin="0,0,4,0"/>
                                <Button Content="Glacial (60s)" Command="{Binding ApplyGlacialRespawnCommand}"
                                        ToolTip="One-click: global hero respawn = 60000ms (near-permadeath feel without flag)"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Edit field: " VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <ComboBox Width="160" ItemsSource="{Binding EditFieldOptions}" SelectedItem="{Binding EditField}" VerticalAlignment="Top"/>
                                <TextBlock Text="    Value: " Margin="12,4,0,0" VerticalAlignment="Top"/>
                                <TextBox Width="100" Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top"/>
                                <StackPanel Margin="10,0,0,0">
                                    <Button Content="Apply" Command="{Binding EditStatCommand}"/>
                                    <TextBlock Text="{Binding EditStat.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding EditStat.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <Border Grid.Row="4" Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <!-- =================================================== TAB 15: Battle Control (Unit D) -->
            <!-- iter 55: per-button capability badges + tab-level Phase-2-pending
                 warning. ToggleFreezeAi + Set/ClearUnitCap are still Phase-1-mirror
                 only; Kill/Heal/InstantWin are LIVE. -->
            <TabItem Header="Battle Control" ToolTip="{Binding TooltipBattleControl}">
                <ScrollViewer DataContext="{Binding BattleControl}" Margin="12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{DynamicResource WarningBackground}"
                                BorderBrush="{DynamicResource WarningBorderBrush}"
                                BorderThickness="1"
                                Padding="8,6" Margin="0,0,0,8"
                                Visibility="{Binding HasPhase2PendingAction, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Phase2PendingWarning}"
                                       Foreground="{DynamicResource WarningForeground}"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <GroupBox Header="Target">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Slot: "/>
                                <TextBox Width="60" Text="{Binding TargetSlot, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="    AI frozen: " Margin="12,0,0,0" Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Text="{Binding IsFreezeAiEnabled}" Foreground="{DynamicResource AccentForeground}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="One-click">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Toggle freeze AI" Command="{Binding ToggleFreezeAiCommand}"/>
                                    <TextBlock Text="{Binding ToggleFreezeAi.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ToggleFreezeAi.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Kill all enemies" Command="{Binding KillAllEnemiesCommand}"/>
                                    <TextBlock Text="{Binding KillAllEnemies.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding KillAllEnemies.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <Button Content="Heal all local" Command="{Binding HealAllLocalCommand}"/>
                                    <TextBlock Text="{Binding HealAllLocal.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding HealAllLocal.Tooltip}"/>
                                </StackPanel>
                                <!--
                                    2026-04-27: composite "Instant win" runs
                                    Heal all local THEN Kill all enemies in
                                    sequence. Pure UX shortcut; no new bridge
                                    behaviour, just one click instead of two.
                                -->
                                <StackPanel>
                                    <Button Content="Instant win"
                                            Command="{Binding InstantWinCommand}"
                                            FontWeight="Bold"
                                            Background="{DynamicResource ConnectedBackground}"
                                            Foreground="White"
                                            ToolTip="Heal all local units, then kill every enemy. Runs the two underlying commands in sequence — pure UX shortcut, no new engine behaviour."/>
                                    <TextBlock Text="{Binding InstantWin.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding InstantWin.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Unit cap override">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Cap (-1 = unlimited): "/>
                                <TextBox Width="100" Text="{Binding UnitCap, UpdateSourceTrigger=PropertyChanged}"/>
                                <!--
                                    2026-04-27: live hint of what the cap
                                    will mean. UnitCapHint reflects sane
                                    range / unlimited / warning text so the
                                    operator catches "0 means wipe-on-spawn"
                                    before clicking Apply.
                                -->
                                <TextBlock Text="{Binding UnitCapHint}"
                                           Foreground="{DynamicResource MutedForeground}"
                                           FontStyle="Italic"
                                           Margin="8,0,8,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel Margin="10,0,0,0">
                                    <Button Content="Apply cap" Command="{Binding SetUnitCapCommand}"/>
                                    <TextBlock Text="{Binding SetUnitCap.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding SetUnitCap.Tooltip}"/>
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <Button Content="Clear (revert)" Command="{Binding ClearUnitCapCommand}"/>
                                    <TextBlock Text="{Binding ClearUnitCap.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" ToolTip="{Binding ClearUnitCap.Tooltip}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <Border Background="{DynamicResource StatusBackground}" Padding="6" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CapabilityBadge, TargetNullValue=' ', FallbackValue=' '}" Foreground="{DynamicResource MutedForeground}" FontWeight="Bold" Margin="0,0,12,0" FontSize="11"/>
                            <TextBlock Text="{Binding LastStatus}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace" FontSize="11"/>
                        </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- =================================================== TAB 16: Story Events (Unit D) -->
            <TabItem Header="Story Events" ToolTip="{Binding TooltipStoryEvents}">
                <Grid DataContext="{Binding StoryEvents}" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Text="Event browser (filter):"/>
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,8"
                             ItemsSource="{Binding FilteredEvents}" SelectedItem="{Binding SelectedEventId}"/>
                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1">
                        <GroupBox Header="Fire event">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Selected: "/>
                                <TextBlock Text="{Binding SelectedEventId}" Foreground="{DynamicResource AccentForeground}" FontFamily="Consolas, Lucida Console, monospace"/>
                                <Button Content="Fire" Command="{Binding FireEventCommand}" Margin="10,0,0,0"
                                        ToolTip="SWFOC_DoString → calls Story_Event(id) on the engine to trigger the selected event. No-op if the event id isn't registered."/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Set story flag">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Name: "/>
                                <!--
                                    2026-04-27: editable ComboBox bound to
                                    the curated FlagNameSuggestions list. Mod
                                    flags still work via IsEditable=True.
                                -->
                                <ComboBox Width="180"
                                          IsEditable="True"
                                          ItemsSource="{Binding FlagNameSuggestions}"
                                          Text="{Binding FlagName, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Pick a common Petroglyph flag (game_won, tutorial_complete, …) or type a custom mod-defined name."/>
