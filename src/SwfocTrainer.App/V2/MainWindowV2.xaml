                                            Margin="0,0,6,0" Padding="8,3"
                                            ToolTip="Create_Generic_Object engine API has DIFFERENT param order: (type, position, player). The dispatcher reorders the 3 fields above so operators don't have to re-type. Catalog rationale + pin tests document the gotcha."/>
                                    <TextBlock Text="{Binding CreateGenericObjectLua.Badge}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForeground}"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding CreateGenericObjectLua.Tooltip}"/>
