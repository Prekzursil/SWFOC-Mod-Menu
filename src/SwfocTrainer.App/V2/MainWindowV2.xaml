                                           Foreground="{DynamicResource WarningForeground}"
                                           FontWeight="Bold" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Type ID: "/>
                            <TextBox Width="180" Text="{Binding StoryArrivalTypeId, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Engine-XML object type id (e.g. Rebel_T2A_Tank)."/>
