                                    <TextBlock Text="    Planet name (Lua): " VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBox Width="160" Text="{Binding FindPlanetNameLuaExpr, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Lua string for the planet name (e.g. &quot;CORUSCANT&quot;). Used by Find planet."/>
                                </StackPanel>
                                <WrapPanel Orientation="Horizontal" Margin="0,2,0,4">
                                    <Button Content="Find object type"
