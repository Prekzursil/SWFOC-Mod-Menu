                                             Text="{Binding CameraExtraArg, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas, Lucida Console, monospace"
                                             ToolTip="Single arg shared across the 4 buttons. Type a number for time/degrees, or a Lua expression for target."/>
                                </StackPanel>
                                <WrapPanel>
                                    <Button Content="Zoom (time)"
