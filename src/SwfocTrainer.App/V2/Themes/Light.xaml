<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Light theme palette. Every key here mirrors a key in Dark.xaml; both
        are loaded and swapped by ThemeService.ApplyTheme(). Colours chosen
        for sufficient contrast against pure white and to avoid harsh blue
        glare — slightly desaturated to match the trainer's "tactical-tool"
        visual language.
    -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="WindowBackground"  Color="#F5F7FA"/>
    <SolidColorBrush x:Key="ChromeBackground"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabBackground"     Color="#ECEFF4"/>
    <SolidColorBrush x:Key="ListBackground"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AltRowBackground"  Color="#F5F7FA"/>
    <SolidColorBrush x:Key="StatusBackground"  Color="#E5EBF3"/>

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="TextForeground"    Color="#1A2333"/>
    <SolidColorBrush x:Key="AccentForeground"  Color="#2D4A78"/>
    <SolidColorBrush x:Key="HeaderForeground"  Color="#4A5C7A"/>
    <SolidColorBrush x:Key="MutedForeground"   Color="#5A6B85"/>
    <SolidColorBrush x:Key="DimForeground"     Color="#8B9AAB"/>
    <SolidColorBrush x:Key="ListForeground"    Color="#2D3A4D"/>

    <!-- Edges -->
    <SolidColorBrush x:Key="BorderBrushBase"   Color="#C5D0DE"/>
    <SolidColorBrush x:Key="BorderBrushStrong" Color="#A8B5C8"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackground"  Color="#E0E5EC"/>
    <SolidColorBrush x:Key="ButtonForeground"  Color="#1A2333"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#A8B5C8"/>

    <!-- ComboBox interactions -->
    <SolidColorBrush x:Key="ItemHoverBackground"    Color="#D0DAE8"/>
    <SolidColorBrush x:Key="ItemHoverForeground"    Color="#0F1621"/>
    <SolidColorBrush x:Key="ItemSelectedBackground" Color="#6586B5"/>
    <SolidColorBrush x:Key="ItemSelectedForeground" Color="#FFFFFF"/>

    <!-- Input fields (TextBox / ComboBox / PasswordBox) -->
    <SolidColorBrush x:Key="InputBackground"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputForeground"        Color="#1A2333"/>
    <SolidColorBrush x:Key="InputBorderBrush"       Color="#A8B5C8"/>
    <SolidColorBrush x:Key="InputCaretBrush"        Color="#1A2333"/>

    <!-- Status banners -->
    <SolidColorBrush x:Key="ConnectedBackground"    Color="#66BB6A"/>
    <SolidColorBrush x:Key="DisconnectedBackground" Color="#E57373"/>
    <!-- Warning banner brushes — see Dark.xaml comment. Amber on white. -->
    <SolidColorBrush x:Key="WarningBackground"      Color="#FFF3CD"/>
    <SolidColorBrush x:Key="WarningForeground"      Color="#664D03"/>
    <SolidColorBrush x:Key="WarningBorderBrush"     Color="#FFE69C"/>

    <!-- iter 65: activity-log duration color-coding. Light-theme variants
         tuned for white background; greens/ambers/reds slightly darker than
         the dark-theme palette to keep contrast against AltRowBackground. -->
    <SolidColorBrush x:Key="DurationFastBrush"      Color="#1F7A1F"/>
    <SolidColorBrush x:Key="DurationNormalBrush"    Color="#1A2333"/>
    <SolidColorBrush x:Key="DurationSlowBrush"      Color="#B86E00"/>
    <SolidColorBrush x:Key="DurationVerySlowBrush"  Color="#B22222"/>

    <!-- iter 70: bridge-health dot. Light-theme variants tuned against
         ChromeBackground (white). -->
    <SolidColorBrush x:Key="BridgeHealthHealthyBrush"  Color="#2E7D32"/>
    <SolidColorBrush x:Key="BridgeHealthDegradedBrush" Color="#E65100"/>
    <SolidColorBrush x:Key="BridgeHealthFailingBrush"  Color="#B71C1C"/>

    <!--
        Input-control styles. Mirrors the unkeyed implicit styles in Dark.xaml
        so theme swaps via ThemeService.ApplyPreference stay live without
        rebinding. See Dark.xaml comment for the bug history.
    -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{DynamicResource InputCaretBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource ItemSelectedBackground}"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource InputForeground}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource InputForeground}"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource InputForeground}"/>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
        <Setter Property="Padding" Value="6,3"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource ItemHoverBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource ItemHoverForeground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource ItemSelectedBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource ItemSelectedForeground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
